# =============================================================================
# Conduit Control Center — Nginx Virtual Host Configuration
# Issues: #34 (rate limiting), #7 (TLS virtual host, HTTP→HTTPS redirect), #32 (security headers)
# =============================================================================
#
# DEPLOYMENT NOTES
# ----------------
# Steps 1–3 are automated by install.sh (Issue #9). Manual steps are only
# needed when deploying without install.sh (e.g. a bare dev server).
#
# Automated path (install.sh):
#   install.sh Phase 2h copies this file to sites-available (with
#   CF_RECORD_NAME substituted), creates the sites-enabled symlink, and
#   writes the rate-limiting zone to /etc/nginx/conf.d/conduit-cc-ratelimit.conf.
#   No manual steps required.
#
# Manual path (dev / custom deploy):
# 1. Substitute <CF_RECORD_NAME> with your actual hostname:
#       sed "s|<CF_RECORD_NAME>|your.hostname|g" conduit-cc.nginx \
#           > /etc/nginx/sites-available/conduit-cc
# 2. Symlink to sites-enabled:
#       sudo ln -s /etc/nginx/sites-available/conduit-cc \
#                  /etc/nginx/sites-enabled/conduit-cc
# 3. Write the rate-limiting zone (see STEP 1 below) to a file in
#    /etc/nginx/conf.d/ (Ubuntu's stock nginx.conf includes conf.d/*.conf
#    inside the http block automatically):
#       sudo tee /etc/nginx/conf.d/conduit-cc-ratelimit.conf < /dev/stdin
# 4. Verify syntax:   sudo nginx -t
# 5. Reload:          sudo systemctl reload nginx
#
# File path note: Issue #7 originally specified scripts/conduit-cc.conf.
# This project uses deployment/ for deployment artefacts and scripts/ for
# executable scripts — the path was established in Issue #34 and is kept here.
#
# =============================================================================
# STEP 1 — Rate-limiting zone (write to /etc/nginx/conf.d/conduit-cc-ratelimit.conf)
# =============================================================================
#
# Ubuntu's stock nginx.conf includes /etc/nginx/conf.d/*.conf inside the
# http { } block automatically — no manual edits to nginx.conf required.
#
#   limit_req_zone $binary_remote_addr zone=login_limit:10m rate=10r/m;
#
# 10 r/m ≈ 1 request every 6 seconds per unique IP address.
# 10 MB zone holds ~160,000 IP state entries.
#

# =============================================================================
# Block 1 — HTTP: redirect all traffic to HTTPS (Issue #7)
# =============================================================================
#
# Cloudflare handles the public-facing HTTP→HTTPS redirect for proxied
# requests.  This block catches any direct HTTP access to the origin server
# (e.g. during install verification, or if the Cloudflare proxy is briefly
# disabled) and returns a permanent redirect.

server {
    listen      80;
    listen      [::]:80;
    server_name <CF_RECORD_NAME>;   # replaced by install.sh (Issue #9)

    return 301 https://$host<CF_HTTPS_REDIRECT_SUFFIX>$request_uri;
}

# =============================================================================
# Block 2 — HTTPS: TLS termination, proxy passthrough (Issue #7)
# =============================================================================

server {
    listen      <CF_HTTPS_PORT> ssl;
    listen      [::]:<CF_HTTPS_PORT> ssl;
    server_name <CF_RECORD_NAME>;   # replaced by install.sh (Issue #9)

    # ------------------------------------------------------------------
    # TLS — Cloudflare Origin Certificate
    #
    # Certificates are installed by install.sh (Issue #9, Phase 2e).
    # Primary TLS model: Cloudflare Proxy + Origin Certificate +
    # SSL/TLS mode set to Full (strict) in the Cloudflare dashboard.
    # See docs/tls-setup.md (Issue #8) for setup instructions.
    # ------------------------------------------------------------------
    ssl_certificate     /etc/conduit-cc/tls/origin.pem;
    ssl_certificate_key /etc/conduit-cc/tls/origin.key;

    ssl_protocols             TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_session_cache         shared:SSL:10m;
    ssl_session_timeout       1d;

    server_tokens off;

    # ------------------------------------------------------------------
    # Cloudflare real-IP restoration (Issue #7)
    #
    # When Nginx sits behind Cloudflare, $remote_addr is a Cloudflare
    # edge node IP, not the real visitor IP.  The directives below restore
    # $remote_addr from the CF-Connecting-IP header so that rate limiting
    # zones and access logs reflect the real visitor address.
    #
    # Only connections from Cloudflare's published IP ranges are trusted
    # to supply this header.  Direct connections from other IPs are NOT
    # trusted, so a non-Cloudflare client cannot spoof their address by
    # setting CF-Connecting-IP manually.
    #
    # Cloudflare IPv4 ranges
    # Source : https://www.cloudflare.com/ips-v4
    # Verified: 2025-05-01 — re-verify before deploying.
    # install.sh (Issue #9) may refresh these ranges at install time.
    # ------------------------------------------------------------------
    set_real_ip_from 173.245.48.0/20;
    set_real_ip_from 103.21.244.0/22;
    set_real_ip_from 103.22.200.0/22;
    set_real_ip_from 103.31.4.0/22;
    set_real_ip_from 141.101.64.0/18;
    set_real_ip_from 108.162.192.0/18;
    set_real_ip_from 190.93.240.0/20;
    set_real_ip_from 188.114.96.0/20;
    set_real_ip_from 197.234.240.0/22;
    set_real_ip_from 198.41.128.0/17;
    set_real_ip_from 162.158.0.0/15;
    set_real_ip_from 104.16.0.0/13;
    set_real_ip_from 104.24.0.0/14;
    set_real_ip_from 172.64.0.0/13;
    set_real_ip_from 131.0.72.0/22;

    # Cloudflare IPv6 ranges
    # Source : https://www.cloudflare.com/ips-v6
    # Verified: 2025-05-01 — re-verify before deploying.
    set_real_ip_from 2400:cb00::/32;
    set_real_ip_from 2606:4700::/32;
    set_real_ip_from 2803:f800::/32;
    set_real_ip_from 2405:b500::/32;
    set_real_ip_from 2405:8100::/32;
    set_real_ip_from 2a06:98c0::/29;
    set_real_ip_from 2c0f:f248::/32;

    real_ip_header CF-Connecting-IP;

    # ------------------------------------------------------------------
    # Security headers — Issue #32
    #
    # These six directives apply to all responses that do NOT have their
    # own add_header in a child location block (nginx inheritance rule:
    # a location with any add_header does not inherit these).
    #
    # Locations that inherit these headers automatically:
    #   /api/auth/login  — no add_header in that block
    #   /api/            — no add_header in that block
    #   /                — no add_header in that block
    #
    # Locations that do NOT inherit (must repeat headers explicitly):
    #   /static/             — has add_header Cache-Control
    #   @login_rate_limited  — has add_header Retry-After
    #
    # HSTS (Strict-Transport-Security)
    #   max-age=31536000: browsers will enforce HTTPS for 1 year.
    #   includeSubDomains: covers all subdomains of CF_RECORD_NAME.
    #   No 'preload' directive: preload is permanent and requires
    #   submission to hstspreload.org; inappropriate for a project
    #   where the operator controls the domain.
    #
    # CSP (Content-Security-Policy)
    #   default-src 'self': all resource types fall back to same-origin.
    #   script-src 'self':  only /static/js/*.js served from this origin.
    #   style-src 'self':   only /static/css/*.css served from this origin.
    #   img-src 'self' data:: same-origin images + data: URIs (future use).
    #   frame-ancestors 'none': this page may not be embedded in any frame.
    #   No unsafe-inline, no unsafe-eval, no nonces, no hashes.
    #   Pre-condition: Issue #44 extracted all inline scripts and styles.
    #
    # X-Frame-Options
    #   Belt-and-suspenders alongside frame-ancestors 'none' in the CSP.
    #   Older browsers that do not support CSP frame-ancestors use this.
    #
    # ------------------------------------------------------------------
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header Content-Security-Policy   "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; frame-ancestors 'none'" always;
    add_header X-Frame-Options           "DENY" always;
    add_header X-Content-Type-Options    "nosniff" always;
    add_header Referrer-Policy           "no-referrer" always;
    add_header Permissions-Policy        "geolocation=(), camera=(), microphone=()" always;

    # ------------------------------------------------------------------
    # Static frontend assets served directly by Nginx
    # Nginx serves /static/ files without hitting the FastAPI process,
    # reducing application load for CSS/JS/image requests.
    # ------------------------------------------------------------------
    location /static/ {
        alias   /opt/conduit-cc/frontend/static/;
        expires 1d;
        # Cache-Control is specific to static assets.
        # Security headers are repeated here because this location has its
        # own add_header, which suppresses server-block header inheritance.
        add_header Cache-Control             "public, no-transform";
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
        add_header Content-Security-Policy   "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; frame-ancestors 'none'" always;
        add_header X-Frame-Options           "DENY" always;
        add_header X-Content-Type-Options    "nosniff" always;
        add_header Referrer-Policy           "no-referrer" always;
        add_header Permissions-Policy        "geolocation=(), camera=(), microphone=()" always;
    }

    # ------------------------------------------------------------------
    # Login endpoint — rate limited (Issue #34)
    #
    # limit_req_zone must be declared in the http block (see STEP 1).
    # burst=9: up to 9 requests served immediately before rate kicks in.
    # nodelay: burst requests are served at once, not queued.
    #
    # When the rate limit is exceeded Nginx generates a 429.  The
    # error_page directive routes that 429 to the @login_rate_limited
    # named location, which adds the Retry-After header and returns a
    # JSON body.
    #
    # This pattern (named location for error responses) avoids placing
    # add_header in this location block directly.  If add_header were
    # used here, Nginx's inheritance rules would suppress any security
    # headers set at the server block level on all responses from this
    # location — including normal 200 proxy responses (Issue #32).
    # ------------------------------------------------------------------
    location /api/auth/login {
        limit_req        zone=login_limit burst=9 nodelay;
        limit_req_status 429;
        error_page       429 = @login_rate_limited;

        proxy_pass         http://127.0.0.1:8000;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # Named location: 429 response for login rate limiting.
    # Kept separate so add_header here does not affect the security
    # header inheritance for the /api/auth/login location above.
    # Security headers are repeated here because this location has its
    # own add_header (Retry-After), which suppresses server-block
    # header inheritance (Issue #32).
    location @login_rate_limited {
        add_header Retry-After               1 always;
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
        add_header Content-Security-Policy   "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; frame-ancestors 'none'" always;
        add_header X-Frame-Options           "DENY" always;
        add_header X-Content-Type-Options    "nosniff" always;
        add_header Referrer-Policy           "no-referrer" always;
        add_header Permissions-Policy        "geolocation=(), camera=(), microphone=()" always;
        return 429 '{"detail":"Rate limit exceeded. Try again in 1 second."}';
    }

    # ------------------------------------------------------------------
    # All other API routes
    # ------------------------------------------------------------------
    location /api/ {
        # Backup restore/inspect upload encrypted .cccbak files (S4B-2.4). The
        # app enforces its own 10 MiB per-endpoint guard; this is set just above
        # it so an in-range upload reaches FastAPI and gets a clean app-level 413,
        # while oversize bodies are rejected here. Bare directive (no add_header),
        # so server-block security-header inheritance is preserved.
        client_max_body_size 12m;

        proxy_pass         http://127.0.0.1:8000;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # ------------------------------------------------------------------
    # Dashboard and all remaining routes
    # ------------------------------------------------------------------
    location / {
        proxy_pass         http://127.0.0.1:8000;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}
