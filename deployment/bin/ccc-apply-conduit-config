#!/usr/bin/python3
# SPDX-License-Identifier: MIT
"""
ccc-apply-conduit-config -- M2 privileged helper (runs as root via one sudoers
line). The SOLE trust boundary for writing Conduit's CCC-managed config.

Security contract (do not weaken):
  * argv-only; NEVER a shell (no os.system / shell=True / eval).
  * Subcommands: only `apply` and `rollback`.
  * apply accepts ONLY integer knobs: --max-common-clients N, --bandwidth-mbps M,
    and the optional --max-personal-clients P (default 0). Personal clients are
    an integer COUNT only: the helper NEVER accepts, writes, or logs a compartment
    ID, and NEVER takes --compartment-id. The compartment ID lives solely in
    personal_compartment.json, auto-loaded by Conduit (never in the unit/drop-in).
  * STATELESS by design: the helper does NOT read the existing drop-in and does
    NOT merge/preserve unspecified values -- it renders exactly the knobs it is
    given (omitted optional knobs render their disabled default). The CALLER is
    responsible for passing the full current knob set on every apply: future
    callers (C6) must read current values -> merge the requested change -> apply
    the complete set, or unrelated settings will be reset. (No merge logic here.)
  * Hardcoded drop-in path and unit name; NEVER takes a path or unit argument.
  * Writes ONLY Environment= lines to the drop-in; NEVER ExecStart or any other
    directive; integer values emitted as %d. The only string values are the
    reduced-window times, which the helper FORMATS ITSELF as HH:MM from
    validated integer minutes (never a raw argv string) -- so an injected
    newline or directive is impossible by construction.
  * Re-validates ranges independently of the API (defense in depth).
  * Reduced-window args (BS1) are OPTIONAL with a disabled default; their
    absence -- or the disabled sentinel -- renders the window OFF (empty times,
    zero limits), preserving the original two-argument M2 apply behaviour.
  * Atomic write: mkstemp in the same root-owned dir, fsync, os.replace.
  * Symlink/TOCTOU defense: verify the drop-in dir is a real, root-owned,
    non-symlink directory; backup read with O_NOFOLLOW.
  * Serialized with an flock on a root-owned lock file.
  * Structured journal/syslog logging; no secrets (none exist here).

Exit codes: 0 success; 2 validation/usage error; 3 filesystem/safety error;
4 systemctl (daemon-reload/restart) error.
"""
from __future__ import annotations

import argparse
import logging
import logging.handlers
import os
import sys
import tempfile

try:
    import fcntl
except ImportError:  # non-Linux (e.g. Windows CI loading the module for tests)
    fcntl = None  # production runs on Linux; _acquire_lock requires fcntl there

# --- Hardcoded, non-overridable constants (no path/unit ever comes from argv) ---
DROPIN_DIR = "/etc/systemd/system/conduit.service.d"
DROPIN_PATH = DROPIN_DIR + "/ccc.conf"
BAK_PATH = DROPIN_DIR + "/ccc.conf.bak"
# Lock lives OUTSIDE the drop-in dir: under conduit-cc.service ProtectSystem=strict
# the helper (run via sudo, inside that namespace) writes the drop-in via a narrow
# ReadWritePaths grant on DROPIN_DIR, but the serialisation lock belongs in the
# already-writable, non-systemd /etc/conduit-cc. Opened O_NOFOLLOW; flock only.
LOCK_PATH = "/etc/conduit-cc/ccc-apply-conduit-config.lock"
UNIT = "conduit"
SYSTEMCTL = "/usr/bin/systemctl"

# Ranges -- MUST match backend/conduit/config_validation.py (parity test asserts).
MCC_MIN, MCC_MAX = 1, 1000
MPC_MIN, MPC_MAX = 0, 1000            # max personal clients (0 = personal mode off)
BW_UNLIMITED, BW_MIN, BW_MAX = -1, 1, 1000
# Reduced-window ranges (BS1). Times are minutes-since-midnight, UTC.
# Disabled sentinel: start=-1, end=-1, reduced-max=0, reduced-bandwidth=0.
RMIN_MIN, RMIN_MAX = 0, 1439          # 00:00 .. 23:59
RMC_MIN, RMC_MAX = 1, 1000            # reduced max common clients (also <= MCC)
RBW_MIN, RBW_MAX = 1, 1000            # reduced bandwidth Mbps (0 only when disabled)
RDISABLED = (-1, -1, 0, 0)            # (start_min, end_min, reduced_max, reduced_bw)
REDUCED_OFF = ("", "", 0, 0, 0)      # render-ready disabled tuple

EXIT_OK, EXIT_USAGE, EXIT_FS, EXIT_SYSTEMCTL = 0, 2, 3, 4


def _make_logger() -> logging.Logger:
    # Never let a logging-handler hiccup (e.g. /dev/log unavailable) raise or
    # spam stderr; logging is best-effort here.
    logging.raiseExceptions = False
    log = logging.getLogger("ccc-apply-conduit-config")
    log.setLevel(logging.INFO)
    # Linux production: journald via /dev/log (AF_UNIX). Other platforms (e.g.
    # Windows CI importing this module for tests) lack AF_UNIX/dev/log, so the
    # syslog handler is Linux-only; stderr logging is always present.
    if sys.platform == "linux":
        try:
            h = logging.handlers.SysLogHandler(address="/dev/log")
            h.setFormatter(logging.Formatter("ccc-apply-conduit-config: %(message)s"))
            log.addHandler(h)
        except OSError:
            pass
    log.addHandler(logging.StreamHandler(sys.stderr))
    return log


LOG = _make_logger()


def _validate_mcc(value: int) -> int:
    if value < MCC_MIN or value > MCC_MAX:
        _fail(EXIT_USAGE, f"max-common-clients out of range ({MCC_MIN}..{MCC_MAX}): {value}")
    return value


def _validate_mpc(value: int) -> int:
    # Integer count only (0 = personal mode off). Never a compartment ID.
    if value < MPC_MIN or value > MPC_MAX:
        _fail(EXIT_USAGE, f"max-personal-clients out of range ({MPC_MIN}..{MPC_MAX}): {value}")
    return value


def _validate_bw(value: int) -> int:
    if value == BW_UNLIMITED:
        return value
    if value < BW_MIN or value > BW_MAX:
        _fail(EXIT_USAGE, f"bandwidth-mbps must be -1 or {BW_MIN}..{BW_MAX}: {value}")
    return value


def _hhmm(minutes: int) -> str:
    """Format validated minutes-since-midnight as HH:MM (helper-synthesised)."""
    hh, mm = divmod(minutes, 60)
    s = "%02d:%02d" % (hh, mm)
    # Defense in depth: the only string ever written to the unit must be a
    # helper-built HH:MM. Refuse anything that is not exactly that shape.
    if len(s) != 5 or s[2] != ":" or not (s[:2].isdigit() and s[3:].isdigit()):
        _fail(EXIT_USAGE, "internal: malformed reduced time")
    return s


def _validate_reduced(start_min: int, end_min: int, reduced_max: int,
                      reduced_bw: int, mcc: int):
    """Validate the OPTIONAL reduced window.

    Returns a render-ready tuple (start_str, end_str, reduced_max, up_bps,
    down_bps). The disabled sentinel (and the argparse defaults) render OFF.
    Partial configurations are rejected: a window is either fully disabled or
    fully specified.
    """
    if (start_min, end_min, reduced_max, reduced_bw) == RDISABLED:
        return REDUCED_OFF
    if not (RMIN_MIN <= start_min <= RMIN_MAX):
        _fail(EXIT_USAGE, f"reduced-start-min out of range ({RMIN_MIN}..{RMIN_MAX}): {start_min}")
    if not (RMIN_MIN <= end_min <= RMIN_MAX):
        _fail(EXIT_USAGE, f"reduced-end-min out of range ({RMIN_MIN}..{RMIN_MAX}): {end_min}")
    if start_min == end_min:
        _fail(EXIT_USAGE, "reduced-start-min and reduced-end-min must differ")
    if not (RMC_MIN <= reduced_max <= RMC_MAX):
        _fail(EXIT_USAGE, f"reduced-max-common out of range ({RMC_MIN}..{RMC_MAX}): {reduced_max}")
    if reduced_max > mcc:
        _fail(EXIT_USAGE, f"reduced-max-common ({reduced_max}) exceeds max-common-clients ({mcc})")
    if not (RBW_MIN <= reduced_bw <= RBW_MAX):
        _fail(EXIT_USAGE, f"reduced-bandwidth-mbps must be {RBW_MIN}..{RBW_MAX} when enabled: {reduced_bw}")
    bps = int(reduced_bw * 1000 * 1000 / 8)
    return (_hhmm(start_min), _hhmm(end_min), reduced_max, bps, bps)


def _fail(code: int, msg: str) -> None:
    LOG.error(msg)
    sys.exit(code)


def _assert_safe_dir() -> None:
    """Drop-in dir must be a real directory, root-owned, not a symlink."""
    try:
        st = os.lstat(DROPIN_DIR)
    except OSError as exc:
        _fail(EXIT_FS, f"drop-in dir missing: {exc}")
    import stat as _stat
    if _stat.S_ISLNK(st.st_mode):
        _fail(EXIT_FS, "drop-in dir is a symlink -- refusing")
    if not _stat.S_ISDIR(st.st_mode):
        _fail(EXIT_FS, "drop-in path is not a directory")
    if st.st_uid != 0:
        _fail(EXIT_FS, "drop-in dir is not root-owned -- refusing")


def _acquire_lock() -> int:
    if fcntl is None:  # Linux-only; never reached in production (runs on the Pi)
        _fail(EXIT_FS, "file locking unavailable (fcntl missing) -- Linux required")
    fd = os.open(LOCK_PATH, os.O_CREAT | os.O_RDWR | os.O_NOFOLLOW, 0o600)
    fcntl.flock(fd, fcntl.LOCK_EX)
    return fd


def _backup_existing() -> bool:
    """Snapshot the current drop-in to .bak. Return True if a drop-in existed."""
    try:
        fd = os.open(DROPIN_PATH, os.O_RDONLY | os.O_NOFOLLOW)
    except FileNotFoundError:
        # No previous drop-in; clear any stale .bak so rollback unlinks.
        try:
            os.unlink(BAK_PATH)
        except FileNotFoundError:
            pass
        return False
    except OSError as exc:
        _fail(EXIT_FS, f"cannot open existing drop-in: {exc}")
    with os.fdopen(fd, "rb") as src:
        data = src.read()
    _atomic_write(BAK_PATH, data)
    return True


def _atomic_write(path: str, data: bytes) -> None:
    """Write data to path atomically within the (root-owned) drop-in dir."""
    fd, tmp = tempfile.mkstemp(dir=DROPIN_DIR, prefix=".ccc-tmp-")
    try:
        with os.fdopen(fd, "wb") as f:
            f.write(data)
            f.flush()
            os.fsync(f.fileno())
        os.chmod(tmp, 0o644)
        os.replace(tmp, path)  # atomic on the same filesystem
    except OSError as exc:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        _fail(EXIT_FS, f"atomic write failed: {exc}")


def _render(mcc: int, bw: int, reduced=REDUCED_OFF, mpc: int = 0) -> bytes:
    # Integers via %d. The only strings are the reduced start/end, which are
    # either "" or a helper-formatted HH:MM (validated in _hhmm) -- never a raw
    # argv string -- so no newline/directive injection is possible. Defaulting
    # `reduced` to OFF and `mpc` to 0 keeps the original two-argument M2 apply
    # behaviour. mpc is an integer COUNT only -- never a compartment ID (Conduit
    # auto-loads that from personal_compartment.json; it is never written here).
    start_str, end_str, rmax, up_bps, down_bps = reduced
    return (
        "[Service]\n"
        "Environment=CCC_MAX_COMMON_CLIENTS=%d\n"
        "Environment=CCC_MAX_PERSONAL_CLIENTS=%d\n"
        "Environment=CCC_BANDWIDTH_MBPS=%d\n"
        "Environment=CCC_REDUCED_START=%s\n"
        "Environment=CCC_REDUCED_END=%s\n"
        "Environment=CCC_REDUCED_MAXCOMMON=%d\n"
        "Environment=CCC_REDUCED_UP=%d\n"
        "Environment=CCC_REDUCED_DOWN=%d\n"
        % (mcc, mpc, bw, start_str, end_str, rmax, up_bps, down_bps)
    ).encode("ascii")


def _systemctl(*args: str) -> None:
    import subprocess
    try:
        subprocess.run([SYSTEMCTL, *args], check=True, shell=False)  # noqa: S603
    except subprocess.CalledProcessError as exc:
        _fail(EXIT_SYSTEMCTL, f"systemctl {' '.join(args)} failed (rc={exc.returncode})")
    except OSError as exc:
        _fail(EXIT_SYSTEMCTL, f"systemctl {' '.join(args)} not runnable: {exc}")


def cmd_apply(mcc: int, bw: int, reduced=REDUCED_OFF, mpc: int = 0) -> None:
    _assert_safe_dir()
    lock = _acquire_lock()
    try:
        _backup_existing()
        _atomic_write(DROPIN_PATH, _render(mcc, bw, reduced, mpc=mpc))
        _systemctl("daemon-reload")
        _systemctl("restart", UNIT)
        # mpc is a non-secret integer count; no compartment info is ever logged.
        start_str, end_str, rmax, up_bps, _down = reduced
        if start_str:
            LOG.info(
                "apply ok: mcc=%d mpc=%d bw=%d reduced=%s-%s UTC max=%d up=down=%d",
                mcc, mpc, bw, start_str, end_str, rmax, up_bps,
            )
        else:
            LOG.info("apply ok: mcc=%d mpc=%d bw=%d reduced=off", mcc, mpc, bw)
    finally:
        os.close(lock)


def cmd_rollback() -> None:
    _assert_safe_dir()
    lock = _acquire_lock()
    try:
        if os.path.exists(BAK_PATH):
            with os.fdopen(os.open(BAK_PATH, os.O_RDONLY | os.O_NOFOLLOW), "rb") as f:
                data = f.read()
            _atomic_write(DROPIN_PATH, data)
            LOG.info("rollback ok: restored previous drop-in")
        else:
            try:
                os.unlink(DROPIN_PATH)
                LOG.info("rollback ok: removed drop-in (no previous config)")
            except FileNotFoundError:
                LOG.info("rollback ok: no drop-in present")
        _systemctl("daemon-reload")
        _systemctl("restart", UNIT)
    finally:
        os.close(lock)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(prog="ccc-apply-conduit-config", add_help=True)
    sub = parser.add_subparsers(dest="cmd", required=True)
    p_apply = sub.add_parser("apply")
    p_apply.add_argument("--max-common-clients", type=int, required=True)
    p_apply.add_argument("--bandwidth-mbps", type=int, required=True)
    # Personal clients (C3): OPTIONAL integer count, default 0 (= personal mode
    # off), so the original two-argument M2 apply still works and renders 0.
    # Integer only -- the helper NEVER accepts a compartment ID or --compartment-id
    # (Conduit auto-loads the ID from personal_compartment.json).
    p_apply.add_argument("--max-personal-clients", type=int, default=0)
    # Reduced-window args are OPTIONAL with a disabled default, so the original
    # two-argument M2 apply call still works and renders the window OFF.
    p_apply.add_argument("--reduced-start-min", type=int, default=-1)
    p_apply.add_argument("--reduced-end-min", type=int, default=-1)
    p_apply.add_argument("--reduced-max-common", type=int, default=0)
    p_apply.add_argument("--reduced-bandwidth-mbps", type=int, default=0)
    sub.add_parser("rollback")
    # argparse rejects unknown args/subcommands -> exit 2 (usage).
    args = parser.parse_args(argv)

    if args.cmd == "apply":
        mcc = _validate_mcc(args.max_common_clients)
        bw = _validate_bw(args.bandwidth_mbps)
        mpc = _validate_mpc(args.max_personal_clients)
        reduced = _validate_reduced(
            args.reduced_start_min,
            args.reduced_end_min,
            args.reduced_max_common,
            args.reduced_bandwidth_mbps,
            mcc,
        )
        cmd_apply(mcc, bw, reduced, mpc=mpc)
    elif args.cmd == "rollback":
        cmd_rollback()
    return EXIT_OK


if __name__ == "__main__":
    sys.exit(main())
