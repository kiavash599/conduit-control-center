#!/opt/conduit-cc/venv/bin/python3
# SPDX-License-Identifier: MIT
"""
ccc-restore-apply -- S4B-2.1 privileged restore helper (runs as root via ONE
exact-path sudoers grant; the grant itself is added in a later deployment slice).

Unlike the other CCC helpers, this one is NOT stdlib-only: it reuses the frozen,
CI-green restore engine (open_backup / restore_backup) rather than re-implementing
crypto as root. It therefore runs under the venv interpreter and imports
backend.backup. Imports are LAZY (inside _load_backend) so the module loads for
unit tests without pulling the backend package.

Flow
----
  1. Read a framed payload (ciphertext + passphrase) from STDIN only.
  2. Under the shared lifecycle lock, create an attempt-recorded root-only FIFO
     handoff and launch this exact helper's internal worker in a fixed transient
     systemd unit. Ciphertext/passphrase cross only the FIFO (never disk/argv/env).
  3. WORKER: re-parse and pre-flight the frame, acquire the lifecycle lock, then
     return the "accepted <id>" ack through a second root-only FIFO. No target
     mutation or service stop occurs before this ack.
  4. WORKER (transient unit): write in_progress -> stop conduit-cc -> take a
     worker-owned checkpoint -> restore_backup() -> start conduit-cc -> require
     systemctl active AND an HTTP health probe. On restore failure OR an
     unhealthy restart, roll back to the worker checkpoint and restart. Write a
     secret-free outcome file.

Security
--------
  * Secrets (passphrase, ciphertext, decrypted bytes) arrive on stdin/FIFO only
    and live in memory; never in argv, env, regular files, outcome, or logs.
  * Outcome/logs carry generic messages only.
  * STATE_DIR is NOT created here (provisioning is deferred to S4B-2.4): if it is
    missing the helper fails cleanly.
  * Lock + atomic writes + hardcoded paths/unit mirror ccc-apply-conduit-config.
"""
from __future__ import annotations

import argparse
import errno
import json
import os
import re
import secrets
import shutil
import stat
import sys
import tempfile
import time
from datetime import datetime, timezone

try:
    import fcntl
except ImportError:                       # Linux-only in production; see _acquire_lock
    fcntl = None

# --- Locked constants (never overridable from argv/env) ---------------------
# ---- Installed-location bootstrap (A5) --------------------------------------
# The application root is DERIVED from this helper's own validated real
# location (<app-root>/bin/<helper> -> <app-root>), never assumed from a
# hardcoded absolute path. Installed at /opt/conduit-cc/bin/... this yields
# exactly /opt/conduit-cc; under the repository layout it yields
# .../deployment (harmless: tests import backend from the repo root). A
# helper executed from a layout whose parent directory is not `bin/` fails
# closed at first privileged use.
_SELF_REAL = os.path.realpath(__file__)
_BIN_DIR = os.path.dirname(_SELF_REAL)
_LAYOUT_OK = os.path.basename(_BIN_DIR) == "bin"
APP_DIR = os.path.dirname(_BIN_DIR) if _LAYOUT_OK else "/invalid-helper-layout"
VENV_PYTHON = f"{APP_DIR}/venv/bin/python3"
CCC_DIR = "/etc/conduit-cc"               # restore target (conduit-cc owned)
# Epic-1 state boundary (F2-class): the restore lock lives in the ROOT-ONLY
# private dir (service cannot delete/replace it to defeat root's mutex); the
# outcome document is PUBLISHED to the service-readable dir whose parent is
# root-owned and not service-writable.
PRIVATE_DIR = "/var/lib/ccc-update"                    # root:root 0700
ATTEMPTS_DIR = f"{PRIVATE_DIR}/attempts"                # root:root 0700
PUBLIC_STATUS_DIR = "/var/lib/ccc-status"              # root:root 0755
OUTCOME_PATH = f"{PUBLIC_STATUS_DIR}/restore-status.json"   # root:conduit-cc 0640
LOCK_PATH = f"{PRIVATE_DIR}/lifecycle.lock"             # shared update/restore mutex
_OWNER_UID = 0                                          # expected state owner (tests inject)
UNIT = "conduit-cc"
HEALTH_URL = "http://127.0.0.1:8000/api/health"
SYSTEMCTL = "/usr/bin/systemctl"
SYSTEMD_RUN = "/usr/bin/systemd-run"
RESTORE_UNIT = "ccc-restore.service"
UPDATE_UNIT = "ccc-update.service"
# S4B-2.6: existing M2 helper used to re-apply the backup's Conduit settings.
# The worker is already root, so it execs this directly (no sudo, no new grant);
# the helper remains the single validation source for the settings values.
APPLY_HELPER_PATH = f"{APP_DIR}/bin/ccc-apply-conduit-config"

# Checkpoint set (mirrors the S3 worker checkpoint; covers restart-health failure).
CHECKPOINT_FILES = ("ccc.db", "ccc.db-wal", "ccc.db-shm", ".env", "config.json")
DB_SIDECARS = ("ccc.db-wal", "ccc.db-shm")

# Size guards (bytes). The blob ceiling is generous vs. a real ccc.db; the nginx
# body cap (raised in a later slice) is the outer bound for uploads.
MAX_BLOB_BYTES = 16 * 1024 * 1024
MAX_PASSPHRASE_BYTES = 1024

# Service wait/health budgets (seconds).
STOP_TIMEOUT_S = 30
START_TIMEOUT_S = 45
HEALTH_TIMEOUT_S = 30
POLL_INTERVAL_S = 0.5
HANDOFF_TIMEOUT_S = 30

# Grace delay (S4B-2.5c) between the worker writing in_progress and stopping
# conduit-cc, so the API's 202 response has time to flush over the socket before
# uvicorn is signalled. Pairs with the API's read-the-ack-and-return design.
GRACE_BEFORE_STOP_S = 2

_RESTORE_ID_RE = re.compile(r"^[0-9a-fA-F][0-9a-fA-F-]{7,63}$")

# --- Exit codes (pre-handoff; post-ack uses the outcome file) ----------------
EXIT_OK = 0
EXIT_USAGE = 2
EXIT_FS = 3
EXIT_SYSTEMCTL = 4
EXIT_BUSY = 5
EXIT_PREFLIGHT = 6
EXIT_INTERNAL = 7


class FrameError(Exception):
    """Malformed stdin frame. Carries only a generic, secret-free message."""


def _log(message: str) -> None:
    """Generic, secret-free log line to stderr (journald in production)."""
    sys.stderr.write("ccc-restore-apply: " + message + "\n")
    sys.stderr.flush()


def _utcnow() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def _fail(code: int, message: str) -> None:
    """Log a generic message and exit with a structured code (pre-ack)."""
    _log(message)
    raise SystemExit(code)


# --------------------------------------------------------------------------- #
# stdin frame                                                                 #
# --------------------------------------------------------------------------- #
def _read_exact(stream, n: int) -> bytes:
    buf = bytearray()
    while len(buf) < n:
        chunk = stream.read(n - len(buf))
        if not chunk:
            break
        buf += chunk
    if len(buf) != n:
        raise FrameError("payload shorter than declared")
    return bytes(buf)


def parse_frame(stream):
    """Parse the CCC-RESTORE/1 frame from a binary stream.

    Returns (restore_id, blob, passphrase). Raises FrameError on any malformation.
    Header is ASCII lines terminated by a blank line; then exactly
    blob_len + passphrase_len bytes follow."""
    magic = stream.readline()
    if magic.strip() != b"CCC-RESTORE/1":
        raise FrameError("bad frame magic")
    header = {}
    for _ in range(16):                   # bounded number of header lines
        line = stream.readline()
        if line in (b"", b"\n", b"\r\n"):
            break
        key, sep, value = line.partition(b":")
        if not sep:
            raise FrameError("malformed header line")
        header[key.strip().decode("ascii", "replace")] = value.strip().decode("ascii", "replace")
    else:
        raise FrameError("header too long")

    try:
        restore_id = header["restore_id"]
        blob_len = int(header["blob_len"])
        pp_len = int(header["passphrase_len"])
    except (KeyError, ValueError):
        raise FrameError("missing or invalid header fields")

    if not _RESTORE_ID_RE.match(restore_id):
        raise FrameError("invalid restore_id")
    if not (0 < blob_len <= MAX_BLOB_BYTES):
        raise FrameError("blob_len out of range")
    if not (0 < pp_len <= MAX_PASSPHRASE_BYTES):
        raise FrameError("passphrase_len out of range")

    payload = _read_exact(stream, blob_len + pp_len)
    return restore_id, payload[:blob_len], payload[blob_len:]


# --------------------------------------------------------------------------- #
# state dir + lock                                                            #
# --------------------------------------------------------------------------- #
def _ensure_app_dir_on_path() -> bool:
    """Establish `import backend...` from the DERIVED application root (A5).
    Returns False (fail closed) if the installed layout is invalid."""
    if not _LAYOUT_OK:
        sys.stderr.write("ccc-restore-apply: MARKER=BAD_LAYOUT invalid installed "
                         "layout (expected <app-root>/bin/<helper>)\n")
        return False
    if APP_DIR not in sys.path:
        sys.path.insert(0, APP_DIR)
    return True


def _state_dir_ok() -> bool:
    """True iff BOTH Epic-1 state dirs exist with correct ownership/mode
    (root-only private dir, root-owned non-service-writable public dir).
    We never create them here: provisioning is install/update's job.
    Emits DISTINCT stderr markers so an import failure can never be mistaken
    for a state failure (installed-layout proof depends on this)."""
    if not _ensure_app_dir_on_path():
        return False
    try:
        from backend.priv_state import (assert_private_dir, assert_public_dir,
                                        PrivStateError)
    except Exception:  # noqa: BLE001 - fail closed without the library
        sys.stderr.write("ccc-restore-apply: MARKER=PRIV_STATE_IMPORT_FAILED\n")
        return False
    sys.stderr.write("ccc-restore-apply: MARKER=PRIV_STATE_IMPORT_OK\n")
    try:
        assert_private_dir(PRIVATE_DIR, _OWNER_UID)
        assert_private_dir(ATTEMPTS_DIR, _OWNER_UID)
        assert_public_dir(PUBLIC_STATUS_DIR, _OWNER_UID)
        return True
    except (PrivStateError, OSError) as exc:
        sys.stderr.write(f"ccc-restore-apply: MARKER=STATE_DIRS_INVALID {exc}\n")
        return False


def acquire_lock(*, blocking: bool = False):
    """Open + flock LOCK_PATH exclusively (non-blocking). Returns the fd.

    Raises SystemExit(EXIT_BUSY) if held, SystemExit(EXIT_FS) on fs/locking error.
    The public apply path uses a nonblocking acquisition. The already-launched
    transient worker uses a blocking acquisition for the lock handoff."""
    if fcntl is None:
        _fail(EXIT_FS, "file locking unavailable (fcntl missing) -- Linux required")
    try:
        if not _ensure_app_dir_on_path():
            _fail(EXIT_FS, "invalid installed layout")
        from backend.priv_state import assert_private_dir, PrivStateError
        assert_private_dir(PRIVATE_DIR, _OWNER_UID)
        fd = os.open(
            LOCK_PATH,
            os.O_CREAT | os.O_WRONLY | os.O_NOFOLLOW | getattr(os, "O_CLOEXEC", 0),
            0o600,
        )
        import stat as _stat
        fst = os.fstat(fd)
        cur = os.lstat(LOCK_PATH)
        if (not _stat.S_ISREG(fst.st_mode) or fst.st_uid != _OWNER_UID
                or fst.st_nlink != 1
                or (cur.st_dev, cur.st_ino) != (fst.st_dev, fst.st_ino)):
            os.close(fd)
            _fail(EXIT_FS, "restore lock failed identity/ownership validation")
    except PrivStateError as exc:
        _fail(EXIT_FS, f"private state dir invalid: {exc}")
    except OSError as exc:
        _fail(EXIT_FS, f"cannot open lock file (rc={exc.errno})")
    try:
        flags = fcntl.LOCK_EX | (0 if blocking else fcntl.LOCK_NB)
        fcntl.flock(fd, flags)
    except OSError:
        os.close(fd)
        _fail(EXIT_BUSY, "another restore is already in progress")
    return fd


# --------------------------------------------------------------------------- #
# backend engine (lazy import)                                                #
# --------------------------------------------------------------------------- #
def _load_backend():
    """Import the frozen restore engine. Returns
    (open_backup, restore_backup, (BackupCryptoError, BackupArchiveError, KeyExclusionError)).
    Raises ImportError if the venv/package is unavailable."""
    if not _ensure_app_dir_on_path():
        raise ImportError("invalid installed layout (bin/ parent required)")
    from backend.backup.archiver import open_backup
    from backend.backup.restore import restore_backup
    from backend.backup.crypto import BackupCryptoError
    from backend.backup.exclusion import KeyExclusionError
    from backend.backup.manifest import BackupArchiveError
    return open_backup, restore_backup, (BackupCryptoError, BackupArchiveError, KeyExclusionError)


def _emit_ack(restore_id: str) -> None:
    sys.stdout.write("accepted " + restore_id + "\n")
    sys.stdout.flush()


# --------------------------------------------------------------------------- #
# worker checkpoint                                                           #
# --------------------------------------------------------------------------- #
def make_checkpoint(ccc_dir: str):
    """Copy current state files into an owner-only checkpoint dir on the same
    filesystem. Returns (ckpt_dir, captured{name: path}). Covers the case S3
    cannot: a successful restore whose new state fails the post-restart health
    check."""
    ckpt = tempfile.mkdtemp(prefix=".ccc-restore-wckpt-", dir=ccc_dir)
    os.chmod(ckpt, 0o700)
    captured = {}
    for name in CHECKPOINT_FILES:
        src = os.path.join(ccc_dir, name)
        # A3: checkpoint reads must not follow symlinks either -- a symlinked
        # checkpoint member (esp. .env) would let root copy an arbitrary host
        # file into service-readable state. Regular files only; anything else
        # is skipped exactly like an absent file (fail-safe, recorded below).
        if os.path.islink(src) or (os.path.exists(src) and not os.path.isfile(src)):
            continue
        if name == ".env" and os.path.exists(src):
            # .env is snapshotted IN MEMORY via the canonical reader; restored
            # via the canonical atomic writer (exact conduit-cc 0600).
            if not _ensure_app_dir_on_path():
                raise OSError("invalid installed layout for env snapshot")
            from backend.env_file import read_env_text
            captured[name] = ("__env_text__", read_env_text(src))
            continue
        if os.path.exists(src):
            dst = os.path.join(ckpt, name)
            shutil.copy2(src, dst)
            os.chmod(dst, 0o600)
            captured[name] = dst
    return ckpt, captured


def restore_checkpoint(ccc_dir: str, captured: dict) -> None:
    for name, ckpt_path in captured.items():
        if isinstance(ckpt_path, tuple) and ckpt_path[0] == "__env_text__":
            if not _ensure_app_dir_on_path():
                raise OSError("invalid installed layout for env restore")
            from backend.env_file import write_env_text
            write_env_text(os.path.join(ccc_dir, name), ckpt_path[1])
            continue
        os.replace(ckpt_path, os.path.join(ccc_dir, name))
    for side in DB_SIDECARS:
        if side not in captured:
            try:
                os.unlink(os.path.join(ccc_dir, side))
            except FileNotFoundError:
                pass


def _cleanup_checkpoint(ckpt_dir) -> None:
    if ckpt_dir:
        shutil.rmtree(ckpt_dir, ignore_errors=True)


# --------------------------------------------------------------------------- #
# service control + health                                                    #
# --------------------------------------------------------------------------- #
def _systemctl(*args: str) -> None:
    import subprocess
    try:
        subprocess.run([SYSTEMCTL, *args], check=True, shell=False)  # noqa: S603
    except subprocess.CalledProcessError as exc:
        raise RuntimeError(f"systemctl {' '.join(args)} failed (rc={exc.returncode})")
    except OSError as exc:
        raise RuntimeError(f"systemctl {' '.join(args)} not runnable (rc={exc.errno})")


def is_active() -> bool:
    import subprocess
    try:
        out = subprocess.run([SYSTEMCTL, "is-active", UNIT],
                             capture_output=True, text=True, shell=False)  # noqa: S603
        return out.stdout.strip() == "active"
    except OSError:
        return False


def health_ok() -> bool:
    import urllib.request
    try:
        with urllib.request.urlopen(HEALTH_URL, timeout=5) as resp:  # noqa: S310 (fixed localhost)
            return 200 <= resp.status < 300
    except Exception:
        return False


def _wait_until(predicate, timeout: float) -> bool:
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if predicate():
            return True
        time.sleep(POLL_INTERVAL_S)
    return predicate()


def stop_service() -> None:
    _systemctl("stop", UNIT)
    if not _wait_until(lambda: not is_active(), STOP_TIMEOUT_S):
        raise RuntimeError("service did not stop in time")


def start_service() -> None:
    _systemctl("start", UNIT)
    _wait_until(is_active, START_TIMEOUT_S)


def restart_healthy() -> bool:
    """Start the unit and confirm BOTH systemctl active AND an HTTP health probe."""
    start_service()
    return _wait_until(lambda: is_active() and health_ok(), HEALTH_TIMEOUT_S)


# --------------------------------------------------------------------------- #
# outcome file                                                                #
# --------------------------------------------------------------------------- #
def write_outcome(state, restore_id, started_utc, finished_utc, restart_ok, message,
                  conduit_settings_state=None) -> None:
    """Atomically write the secret-free outcome JSON (0640, conduit-cc readable).

    Additive `pid` field (S4B-2.5c, schema stays 1): the worker's PID is recorded
    while a restore is in_progress so the API can reconcile a stale in_progress
    (os.kill probe). Terminal states record pid=null.

    Additive `conduit_settings_state` (S4B-2.6, schema stays 1): applied | skipped
    | failed | null -- the result of re-applying the backup's Conduit settings."""
    data = {
        "schema": 1,
        "restore_id": restore_id,
        "state": state,
        "started_utc": started_utc,
        "finished_utc": finished_utc,
        "restart_ok": restart_ok,
        "message": message,
        "pid": os.getpid() if state == "in_progress" else None,
        "conduit_settings_state": conduit_settings_state,
    }
    # Epic-1: publish through the shared SAFE writer (parent/ownership invariants,
    # unpredictable mkstemp, no symlink following, fsync + atomic replace + parent
    # fsync; failure preserves the previous valid outcome document).
    from backend.priv_state import publish_status
    try:
        import grp as _grp
        _gid = _grp.getgrnam("conduit-cc").gr_gid
    except (KeyError, OSError):
        _gid = None                       # account absent (tests); root keeps gid 0
    publish_status(OUTCOME_PATH, data, owner_uid=_OWNER_UID, group_gid=_gid)


# --------------------------------------------------------------------------- #
# restore worker (fixed transient systemd unit)                              #
# --------------------------------------------------------------------------- #
def _hhmm_to_min(value) -> int:
    """Convert an "HH:MM" (UTC, 24h) string to minutes-since-midnight. Raises
    ValueError on anything malformed (caught by the caller -> 'failed')."""
    hh, mm = str(value).split(":")
    h, m = int(hh), int(mm)
    if not (0 <= h <= 23 and 0 <= m <= 59):
        raise ValueError("time out of range")
    return h * 60 + m


def _conduit_apply_argv(cfg) -> list:
    """Map the logical conduit_settings.json (configured=true) to the M2 helper's
    argv. Value-range validation is left to the helper (single source of truth);
    this only converts representation (HH:MM -> minutes). Raises on malformed."""
    argv = [
        "--max-common-clients", str(int(cfg["max_common_clients"])),
        "--bandwidth-mbps", str(int(cfg["bandwidth_mbps"])),
        "--max-personal-clients", str(int(cfg.get("max_personal_clients", 0))),
    ]
    red = cfg.get("reduced") or {}
    if red.get("enabled"):
        argv += [
            "--reduced-start-min", str(_hhmm_to_min(red["start"])),
            "--reduced-end-min", str(_hhmm_to_min(red["end"])),
            "--reduced-max-common", str(int(red["max_common"])),
            "--reduced-bandwidth-mbps", str(int(red["bandwidth_mbps"])),
        ]
    # Disabled reduced window -> rely on the helper argparse defaults (-1,-1,0,0).
    return argv


def _run_apply_helper(argv) -> int:
    """Exec the M2 apply helper directly (we are root). Returns its exit code."""
    import subprocess
    proc = subprocess.run([APPLY_HELPER_PATH, "apply", *argv],
                          capture_output=True, shell=False)
    return proc.returncode


def _apply_conduit_settings(opened):
    """Best-effort re-apply of the backup's Conduit settings (S4B-2.6) via the M2
    helper. Returns (conduit_settings_state, message_suffix). Never raises.
      absent item / configured=false   -> ("skipped", "")
      configured=true + helper success  -> ("applied", " Conduit settings re-applied.")
      malformed / invalid / helper fail -> ("failed",  "...")"""
    try:
        item = None
        for it in opened.staging.items:
            if it.name == "conduit_settings.json":
                item = it
                break
        if item is None:
            return "skipped", ""                       # legacy (pre-2.6) backup
        cfg = json.loads(item.data.decode("utf-8", "replace"))
        if not isinstance(cfg, dict) or cfg.get("schema") != 1:
            return "failed", " Conduit settings were not re-applied (unrecognised format)."
        if not cfg.get("configured"):
            return "skipped", ""                       # nothing was configured
        argv = _conduit_apply_argv(cfg)                # may raise on malformed
    except Exception:
        return "failed", " Conduit settings were not re-applied (malformed)."
    try:
        rc = _run_apply_helper(argv)
    except Exception:
        return "failed", " Conduit settings were not re-applied (helper error)."
    if rc == 0:
        return "applied", " Conduit settings re-applied."
    return "failed", " Conduit settings were not re-applied (validation/apply error)."


def run_worker(opened, restore_backup, restore_id, started_utc, lockfd=None) -> str:
    """Stop -> checkpoint -> restore_backup -> start+health, with rollback that
    also covers restart-health failure. Writes the outcome and returns the final
    state. Never raises; every path produces an outcome.

    On a committed (healthy) restore, re-applies the backup's Conduit settings via
    the M2 helper (best-effort) and records conduit_settings_state. All other
    terminal paths record conduit_settings_state="skipped"."""
    write_outcome("in_progress", restore_id, started_utc, None, None,
                  "Restore in progress; the dashboard is restarting.")
    ckpt = None
    captured = {}
    try:
        # Grace delay so the API's 202 can flush before we stop conduit-cc.
        time.sleep(GRACE_BEFORE_STOP_S)
        stop_service()
        ckpt, captured = make_checkpoint(CCC_DIR)
        result = restore_backup(opened, ccc_dir=CCC_DIR)

        if result.status == "restored":
            if restart_healthy():
                # Committed to "restored": re-apply Conduit settings (best-effort)
                # only now, so a later core rollback can never leave them applied.
                cs_state, cs_note = _apply_conduit_settings(opened)
                _cleanup_checkpoint(ckpt)
                _finish(restore_id, started_utc, "restored", True,
                        "Restore complete; the dashboard restarted successfully." + cs_note,
                        conduit_settings_state=cs_state)
                return "restored"
            # New state prevents a healthy start -> revert to the checkpoint.
            restore_checkpoint(CCC_DIR, captured)
            healthy = restart_healthy()
            _cleanup_checkpoint(ckpt)
            _finish(restore_id, started_utc, "rolled_back", healthy,
                    "Restore was applied but the dashboard did not return healthy; "
                    "the previous state was restored.")
            return "rolled_back"

        # S3 already rolled back internally (or could not). Bring the service back.
        healthy = restart_healthy()
        _cleanup_checkpoint(ckpt)
        _finish(restore_id, started_utc, result.status, healthy,
                "Restore did not complete; the previous state is in place.")
        return result.status

    except BaseException:
        # Best-effort recovery: revert to the checkpoint and restart.
        recovered = False
        try:
            if captured:
                restore_checkpoint(CCC_DIR, captured)
            recovered = restart_healthy()
        except BaseException:
            recovered = False
        _cleanup_checkpoint(ckpt)
        state = "rolled_back" if recovered else "rollback_failed"
        msg = ("Restore failed; the previous state was restored."
               if recovered else
               "Restore failed and automatic recovery did not fully succeed; "
               "manual recovery may be required.")
        _finish(restore_id, started_utc, state, recovered, msg)
        return state
    finally:
        if lockfd is not None:
            try:
                os.close(lockfd)          # release the flock
            except OSError:
                pass


def _finish(restore_id, started_utc, state, restart_ok, message,
            conduit_settings_state="skipped") -> None:
    write_outcome(state, restore_id, started_utc, _utcnow(), restart_ok, message,
                  conduit_settings_state=conduit_settings_state)


# --------------------------------------------------------------------------- #
# transient-unit FIFO handoff                                                 #
# --------------------------------------------------------------------------- #
def _priv_state_module():
    if not _ensure_app_dir_on_path():
        raise RuntimeError("invalid installed layout")
    from backend import priv_state
    return priv_state


def _frame_bytes(restore_id: str, blob: bytes, passphrase: bytes) -> bytes:
    header = (
        "CCC-RESTORE/1\n"
        f"restore_id: {restore_id}\n"
        f"blob_len: {len(blob)}\n"
        f"passphrase_len: {len(passphrase)}\n\n"
    ).encode("ascii")
    return header + blob + passphrase


def _unit_busy(unit: str) -> bool:
    import subprocess
    try:
        proc = subprocess.run(
            [SYSTEMCTL, "is-active", unit],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            check=False,
        )
        return (proc.stdout or "").strip() in {
            "active", "activating", "reloading", "deactivating"
        }
    except OSError:
        return False


def _cleanup_attempt(attempt_id: str, work: str | None = None) -> bool:
    try:
        return _priv_state_module().cleanup_attempt(
            PRIVATE_DIR,
            ATTEMPTS_DIR,
            attempt_id,
            _OWNER_UID,
            argv_work=work,
        )
    except Exception:
        return False


def _prepare_handoff(attempt_id: str) -> tuple[str, str, str]:
    pstate = _priv_state_module()
    work = os.path.join(PRIVATE_DIR, f"ccc-restore-{attempt_id}")
    pstate.record_attempt(
        ATTEMPTS_DIR, attempt_id, work, _OWNER_UID, kind="restore")
    try:
        os.mkdir(work, 0o700)
        os.chmod(work, 0o700)
        payload_fifo = os.path.join(work, "payload.fifo")
        ack_fifo = os.path.join(work, "ack.fifo")
        os.mkfifo(payload_fifo, 0o600)
        os.mkfifo(ack_fifo, 0o600)
        return work, payload_fifo, ack_fifo
    except BaseException:
        _cleanup_attempt(attempt_id, work)
        raise


def _launch_restore_unit(attempt_id: str, restore_id: str, work: str) -> int:
    import subprocess
    cmd = [
        SYSTEMD_RUN, "--collect", "--no-block", "--quiet",
        f"--unit={RESTORE_UNIT}",
        "--description=Conduit Control Center restore",
        _SELF_REAL, "__run-worker",
        "--attempt", attempt_id,
        "--restore-id", restore_id,
        "--work", work,
    ]

    def _try():
        try:
            return subprocess.run(
                cmd,
                stdin=subprocess.DEVNULL,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                check=False,
            )
        except OSError:
            return None

    proc = _try()
    if proc is not None and proc.returncode == 0:
        return 0
    try:
        subprocess.run(
            [SYSTEMCTL, "reset-failed", RESTORE_UNIT],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
    except OSError:
        pass
    proc = _try()
    return 3 if proc is None else (proc.returncode or 1)


def _validate_fifo(path: str) -> None:
    st = os.lstat(path)
    if not stat.S_ISFIFO(st.st_mode) or st.st_uid != _OWNER_UID \
            or stat.S_IMODE(st.st_mode) != 0o600 or st.st_nlink != 1:
        raise OSError("restore handoff FIFO failed identity/ownership validation")


def _validate_open_fifo(path: str, fd: int) -> None:
    """Prove the opened FIFO is still the exact path object we validated."""
    fst = os.fstat(fd)
    cur = os.lstat(path)
    if not stat.S_ISFIFO(fst.st_mode) or fst.st_uid != _OWNER_UID \
            or stat.S_IMODE(fst.st_mode) != 0o600 or fst.st_nlink != 1 \
            or (fst.st_dev, fst.st_ino) != (cur.st_dev, cur.st_ino):
        raise OSError("opened restore FIFO failed identity/ownership validation")


def _open_fifo_writer(path: str, deadline: float) -> int:
    while time.monotonic() < deadline:
        try:
            fd = os.open(
                path,
                os.O_WRONLY | os.O_NONBLOCK | os.O_NOFOLLOW
                | getattr(os, "O_CLOEXEC", 0),
            )
            try:
                _validate_open_fifo(path, fd)
            except BaseException:
                os.close(fd)
                raise
            flags = fcntl.fcntl(fd, fcntl.F_GETFL)
            fcntl.fcntl(fd, fcntl.F_SETFL, flags & ~os.O_NONBLOCK)
            return fd
        except OSError as exc:
            if exc.errno not in (errno.ENXIO, errno.ENOENT):
                raise
            time.sleep(0.05)
    raise TimeoutError("restore worker did not open the payload FIFO")


def _stop_restore_unit() -> None:
    import subprocess
    try:
        subprocess.run(
            [SYSTEMCTL, "stop", RESTORE_UNIT],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
    except OSError:
        pass


def _handoff_and_wait(frame: bytes, restore_id: str, attempt_id: str,
                      work: str, payload_fifo: str, ack_fifo: str,
                      lockfd: int) -> tuple[int, str]:
    import select
    deadline = time.monotonic() + HANDOFF_TIMEOUT_S
    ackfd = -1
    lock_open = True
    launched = False
    try:
        _validate_fifo(payload_fifo)
        _validate_fifo(ack_fifo)
        ackfd = os.open(
            ack_fifo,
            os.O_RDWR | os.O_NONBLOCK | os.O_NOFOLLOW
            | getattr(os, "O_CLOEXEC", 0),
        )
        _validate_open_fifo(ack_fifo, ackfd)
        if _launch_restore_unit(attempt_id, restore_id, work) != 0:
            return EXIT_SYSTEMCTL, ""
        launched = True
        payloadfd = _open_fifo_writer(payload_fifo, deadline)
        try:
            with os.fdopen(payloadfd, "wb", buffering=0) as out:
                out.write(frame)
        finally:
            payloadfd = -1
        # Unit is registered and owns the frame. Release the launch mutex; the
        # worker acquires it before preflight/ack and holds it through restore.
        os.close(lockfd)
        lock_open = False
        data = bytearray()
        while time.monotonic() < deadline and b"\n" not in data:
            remaining = max(0.0, deadline - time.monotonic())
            readable, _, _ = select.select([ackfd], [], [], remaining)
            if not readable:
                continue
            chunk = os.read(ackfd, 256)
            if chunk:
                data.extend(chunk)
        if b"\n" not in data:
            _stop_restore_unit()
            return EXIT_INTERNAL, ""
        line = bytes(data).split(b"\n", 1)[0].decode("ascii", "replace")
        if line == f"accepted {restore_id}":
            return EXIT_OK, line
        if re.fullmatch(r"error [2-7]", line):
            return int(line.split()[1]), line
        # An unrecognised acknowledgement is not a terminal worker result.  The
        # unit may still be running with ownership of this attempt, so fail
        # closed by stopping the complete transient-unit cgroup before the
        # public caller returns an internal error.
        _stop_restore_unit()
        return EXIT_INTERNAL, line
    except BaseException:
        if launched:
            _stop_restore_unit()
        raise
    finally:
        if lock_open:
            os.close(lockfd)
        if ackfd >= 0:
            os.close(ackfd)


def _worker_ack(ack_fifo: str, line: str) -> None:
    _validate_fifo(ack_fifo)
    fd = os.open(
        ack_fifo,
        os.O_WRONLY | os.O_NOFOLLOW | getattr(os, "O_CLOEXEC", 0),
    )
    try:
        _validate_open_fifo(ack_fifo, fd)
        with os.fdopen(fd, "wb", buffering=0) as out:
            fd = -1
            out.write((line + "\n").encode("ascii"))
    finally:
        if fd >= 0:
            os.close(fd)


def _run_worker_entry(attempt_id: str, restore_id: str, argv_work: str) -> int:
    pstate = _priv_state_module()
    ack_fifo = None
    try:
        work = pstate.attempt_work(
            PRIVATE_DIR,
            ATTEMPTS_DIR,
            attempt_id,
            kind="restore",
            owner_uid=_OWNER_UID,
            argv_work=argv_work,
        )
        payload_fifo = os.path.join(work, "payload.fifo")
        ack_fifo = os.path.join(work, "ack.fifo")
        _validate_fifo(payload_fifo)
        _validate_fifo(ack_fifo)
        payloadfd = os.open(
            payload_fifo,
            os.O_RDONLY | os.O_NOFOLLOW | getattr(os, "O_CLOEXEC", 0),
        )
        try:
            _validate_open_fifo(payload_fifo, payloadfd)
            with os.fdopen(payloadfd, "rb", buffering=0) as stream:
                payloadfd = -1
                framed_id, blob, passphrase = parse_frame(stream)
        finally:
            if payloadfd >= 0:
                os.close(payloadfd)
        if framed_id != restore_id:
            _worker_ack(ack_fifo, f"error {EXIT_USAGE}")
            return EXIT_USAGE
        try:
            lockfd = acquire_lock(blocking=True)
        except SystemExit as exc:
            rc = exc.code if isinstance(exc.code, int) else EXIT_INTERNAL
            if rc not in {
                    EXIT_USAGE, EXIT_FS, EXIT_SYSTEMCTL, EXIT_BUSY,
                    EXIT_PREFLIGHT, EXIT_INTERNAL}:
                rc = EXIT_INTERNAL
            _worker_ack(ack_fifo, f"error {rc}")
            return rc
        try:
            open_backup, restore_backup, validation_errors = _load_backend()
            try:
                opened = open_backup(blob, passphrase)
            except validation_errors:
                _worker_ack(ack_fifo, f"error {EXIT_PREFLIGHT}")
                return EXIT_PREFLIGHT
            except Exception:
                _worker_ack(ack_fifo, f"error {EXIT_INTERNAL}")
                return EXIT_INTERNAL
            finally:
                passphrase = None
                blob = None
            started_utc = _utcnow()
            _worker_ack(ack_fifo, f"accepted {restore_id}")
            run_worker(opened, restore_backup, restore_id, started_utc)
            return EXIT_OK
        finally:
            os.close(lockfd)
    except (FrameError, OSError, RuntimeError):
        if ack_fifo is not None:
            try:
                _worker_ack(ack_fifo, f"error {EXIT_FS}")
            except Exception:
                pass
        return EXIT_FS
    except Exception:
        if ack_fifo is not None:
            try:
                _worker_ack(ack_fifo, f"error {EXIT_INTERNAL}")
            except Exception:
                pass
        return EXIT_INTERNAL
    finally:
        _cleanup_attempt(attempt_id, argv_work)


# --------------------------------------------------------------------------- #
# entry point                                                                 #
# --------------------------------------------------------------------------- #
def main(argv=None, stdin=None) -> int:
    args = list(sys.argv[1:] if argv is None else argv)
    os.umask(0o077)

    if args[:1] == ["__run-worker"]:
        parser = argparse.ArgumentParser(add_help=False)
        parser.add_argument("--attempt", required=True)
        parser.add_argument("--restore-id", required=True)
        parser.add_argument("--work", required=True)
        try:
            ns = parser.parse_args(args[1:])
        except SystemExit:
            return EXIT_USAGE
        if not re.fullmatch(r"[0-9a-f]{12}", ns.attempt) \
                or not _RESTORE_ID_RE.fullmatch(ns.restore_id):
            return EXIT_USAGE
        return _run_worker_entry(ns.attempt, ns.restore_id, ns.work)

    if args != ["apply"]:
        return EXIT_USAGE
    stream = stdin if stdin is not None else sys.stdin.buffer
    if not _state_dir_ok():
        _log("state directory missing; provisioning is deferred to deployment")
        return EXIT_FS
    try:
        restore_id, blob, passphrase = parse_frame(stream)
    except FrameError as exc:
        _log("invalid input frame: " + str(exc))
        return EXIT_USAGE
    try:
        lockfd = acquire_lock()
    except SystemExit as exc:
        return exc.code if isinstance(exc.code, int) else EXIT_INTERNAL
    if _unit_busy(RESTORE_UNIT) or _unit_busy(UPDATE_UNIT):
        os.close(lockfd)
        return EXIT_BUSY
    pstate = _priv_state_module()
    if pstate.sweep_stale_attempts(
            PRIVATE_DIR, ATTEMPTS_DIR, _OWNER_UID):
        os.close(lockfd)
        _log("stale attempt cleanup requires Owner diagnosis")
        return EXIT_FS
    attempt_id = secrets.token_hex(6)
    try:
        work, payload_fifo, ack_fifo = _prepare_handoff(attempt_id)
        frame = _frame_bytes(restore_id, blob, passphrase)
        blob = None
        passphrase = None
        try:
            rc, ack = _handoff_and_wait(
                frame, restore_id, attempt_id, work, payload_fifo, ack_fifo, lockfd)
        finally:
            # _handoff_and_wait owns and closes the launch lock on every path.
            lockfd = -1
        frame = b""
        if rc == EXIT_OK:
            sys.stdout.write(ack + "\n")
            sys.stdout.flush()
            return EXIT_OK
        if not _unit_busy(RESTORE_UNIT):
            _cleanup_attempt(attempt_id, work)
        return rc
    except Exception:
        if lockfd >= 0:
            os.close(lockfd)
        if not _unit_busy(RESTORE_UNIT):
            _cleanup_attempt(attempt_id)
        _log("restore worker handoff failed")
        return EXIT_INTERNAL


if __name__ == "__main__":
    try:
        sys.exit(main())
    except SystemExit as _exc:
        raise
    except BaseException:
        _log("fatal internal error")
        sys.exit(EXIT_INTERNAL)
