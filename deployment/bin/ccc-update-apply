#!/usr/bin/python3
# SPDX-License-Identifier: MIT
"""
ccc-update-apply -- privileged, single-purpose CCC updater (Feature 2).

Security contract (DO NOT WEAKEN):
  * Public argv-only CONTROL: the only externally-invoked action is `apply`.
    `apply` NEVER accepts a tag, ref, branch, version, path, URL, or command.
  * The update PAYLOAD (a CCC release SOURCE tarball, .tar.gz) is read from
    STDIN ONLY -- never a filesystem path argument (mirrors ccc-restore-apply).
  * Hardcoded action and nothing else: extract the payload to a recorded work
    tree under the ROOT-ONLY private state dir (/var/lib/ccc-update; Epic-1
    boundary -- never the service-writable StateDirectory), validate it, then
    run the HARDCODED, INSTALLED updater
        /opt/conduit-cc/update.sh --ccc-only --non-interactive --source <tree>
            --authorized-source-commit <signed-commit>
            --authorized-source-tag <signed-tag>
    The helper NEVER executes any script contained in the payload; the payload
    is treated as DATA only (rsynced in by the trusted installed update.sh).
  * Refuses anything that is not a strict version INCREASE over the installed
    APP_VERSION (no downgrade, no reinstall).
  * No secrets are handled or logged.

Execution model (Option B1):
  `apply` runs inside the conduit-cc.service mount namespace (ProtectSystem=strict),
  where deploy targets (/opt, /var/backups, ...) are read-only. It ingests the
  payload into the ROOT-ONLY private state dir (writable in-namespace via the
  unit's ReadWritePaths grant; the service ACCOUNT is still excluded by 0700
  root ownership -- Unix ownership is the boundary, the namespace is
  defense-in-depth), then launches a fixed-name
  systemd TRANSIENT unit (ccc-update.service) that runs THIS trusted helper's
  internal `__run-worker` subcommand in the HOST mount namespace, where update.sh
  can write. Status / logging / cleanup / rollback remain owned by this helper.

    Trusted installed engine decides. Downloaded payload describes.
    Payload never commands privileged control flow.

Exit codes (apply, pre-ack): 0 accepted (unit launched); 2 usage/validation;
  3 filesystem/safety. After the ack the outcome lives in update-status.json.
"""
from __future__ import annotations

import argparse
import datetime
import fcntl
import os
import re
import shutil
import struct
import subprocess
import sys
import tarfile
import time
import uuid
from typing import NoReturn

# ---- Hardcoded, non-overridable constants ----------------------------------
# Epic-1 state boundary (F2): privileged state lives in a ROOT-ONLY directory the
# service account cannot touch; only the minimal status document is published to a
# separate service-READABLE location whose parent is root-owned. The service can
# read the public status but cannot create/replace/rename/symlink/lock/delete
# anything on either side. The unit grants ReadWritePaths for BOTH dirs so that
# root-in-namespace (sudo apply) can write; Unix 0700/0755 root ownership is the
# security boundary, ProtectSystem=strict stays defense-in-depth.
PRIVATE_DIR = "/var/lib/ccc-update"                 # root:root 0700 (locks/work/log/records)
ATTEMPTS_DIR = f"{PRIVATE_DIR}/attempts"            # per-attempt ownership records
PUBLIC_STATUS_DIR = "/var/lib/ccc-status"           # root:root 0755 (published status)
STATUS_PATH = f"{PUBLIC_STATUS_DIR}/update-status.json"   # root:conduit-cc 0640
LOCK_PATH = f"{PRIVATE_DIR}/lifecycle.lock"          # shared update/restore mutex
WORKER_LOG = f"{PRIVATE_DIR}/update-worker.log"     # update.sh stdout/stderr (root 0600)
_OWNER_UID = 0                                      # expected owner of ALL state (tests inject)
# ---- Installed-location bootstrap (A5): the app root is DERIVED from this
# helper's own validated real location (<app-root>/bin/<helper> -> <app-root>),
# never assumed from a hardcoded absolute path. Invalid layouts fail closed.
_SELF_REAL = os.path.realpath(__file__)
_BIN_DIR = os.path.dirname(_SELF_REAL)
_LAYOUT_OK = os.path.basename(_BIN_DIR) == "bin"
_APP_DIR = os.path.dirname(_BIN_DIR) if _LAYOUT_OK else "/invalid-helper-layout"
INSTALLED_UPDATE_SH = f"{_APP_DIR}/update.sh"              # trusted, installed
INSTALLED_VERSION_PY = f"{_APP_DIR}/backend/_version.py"
SELF_PATH = _SELF_REAL                               # trusted installed helper; ExecStart of the transient unit
UPDATE_UNIT = "ccc-update.service"                    # fixed name -> systemd serializes the run phase
RESTORE_UNIT = "ccc-restore.service"                  # mutually exclusive lifecycle operation
SYSTEMD_RUN = "/usr/bin/systemd-run"
SYSTEMCTL = "/usr/bin/systemctl"
PAYLOAD_VERSION_REL = "backend/_version.py"
PAYLOAD_UPDATE_REL = "update.sh"
MAX_PAYLOAD_BYTES = 200 * 1024 * 1024                      # 200 MiB hard cap
_ACTIVE_WAIT_S = 10                                        # apply waits this long for the unit to register
_IN_FLIGHT_UNIT_STATES = frozenset({
    "active", "activating", "reloading", "deactivating",
})
_DEFINITELY_INACTIVE_UNIT_STATES = frozenset({"inactive", "failed"})
_VERSION_RE = re.compile(r'APP_VERSION\s*=\s*"(\d+\.\d+\.\d+)"')
_VER_ARG_RE = re.compile(r'^\d+\.\d+\.\d+$')
TRUST_STORE = f"{_APP_DIR}/trust/allowed_signers"   # ADR-0003 M2 trust store (root-only)
_FRAME_MAGIC = b"CCCU\x01"                               # payload frame header (MUST match backend/api/update.py)

# ADR-0003 verifier (trusted, installed, stdlib-only). Imported fail-closed:
# if it cannot be loaded, verification cannot proceed and the update is rejected.
try:
    if not _LAYOUT_OK:
        raise ImportError("invalid installed layout (bin/ parent required)")
    if _APP_DIR not in sys.path:
        sys.path.insert(0, _APP_DIR)
    from backend.update_verify import (  # noqa: E402
        verify_release, cross_check_version, product_scope_ok,
        # E1/E1.1 frozen outcome codes consumed by the audit writer (no literals):
        OUTCOME_ACCEPTED, OUTCOME_REJECT_PRODUCT_SCOPE, OUTCOME_REJECT_NON_UPGRADE,
        OUTCOME_REJECT_VERSION_MISMATCH, OUTCOME_REJECT_FRAME, OUTCOME_REJECT_PAYLOAD_SHAPE,
        OUTCOME_LAUNCH_FAILED, OUTCOME_APPLIED, OUTCOME_REVERTED, OUTCOME_APPLY_FAILED,
    )
    _VERIFY_AVAILABLE = True
except Exception:  # noqa: BLE001 - fail-closed on any import problem
    _VERIFY_AVAILABLE = False

# Epic-1 privileged-state primitives (symlink-safe publication, private locks,
# attempt-ownership records). Imported FAIL-CLOSED like the verifier: without
# them no status can be published safely, so the helper refuses to run.
try:
    from backend import priv_state as _pstate  # noqa: E402
    _PSTATE_AVAILABLE = True
except Exception:  # noqa: BLE001 - fail-closed on any import problem
    _PSTATE_AVAILABLE = False

# ADR-0003 Phase B: E3 audit writer (best-effort, NON-fatal). Imported SEPARATELY
# from the fail-closed verifier import: if the audit library is unavailable, audit
# recording is silently skipped and the update proceeds unchanged (observability is
# non-authorising; audit failures never alter the trust/deploy/rollback outcome).
try:
    from backend.update_audit import (  # noqa: E402
        build_audit_record, append_record, AUDIT_DIR, AUDIT_FILE,
    )
    _AUDIT_AVAILABLE = True
except Exception:  # noqa: BLE001 - audit is best-effort, never fail-closed
    _AUDIT_AVAILABLE = False

_ATTEMPT_ID = None   # correlation/attempt id for the current run (audit only)
_LAST_META = None    # last verified manifest metadata (audit only; apply-side)

# Audit dir/file end root:conduit-cc (service reads, cannot write/unlink).
# Resolve the group once, best-effort; None -> chown is skipped (still non-fatal).
try:
    import grp as _grp  # noqa: E402
    _CCC_GID = _grp.getgrnam("conduit-cc").gr_gid
except Exception:  # noqa: BLE001 - best-effort; audit never fails on this
    _CCC_GID = None


def log(msg: str) -> None:
    sys.stderr.write(f"ccc-update-apply: {msg}\n")


def die(code: int, msg: str) -> NoReturn:
    log(msg)
    sys.exit(code)


def _now() -> str:
    return datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def _audit(outcome: str, stage: str, **fields) -> None:
    """Best-effort, append-only, NON-FATAL audit record for one update outcome.

    ADR-0003 Phase B / E3 runtime integration. This function NEVER raises, NEVER
    changes control flow, exit code, status content, deployment result, or
    rollback behaviour (observability is non-authorising). It is a no-op if the
    audit library is unavailable. Redaction is enforced by build_audit_record's
    allowlist; only whitelisted primitive fields are recorded. The AppendResult is
    intentionally discarded — an append failure changes nothing.
    """
    if not _AUDIT_AVAILABLE:
        return
    try:
        # Fallback provisioning (installer/updater normally create the dir first).
        # Explicit chmod/chown are required: UMask=0077 in the apply namespace would
        # otherwise make the dir 0700 (blocking service read) and the file 0600.
        try:
            os.makedirs(AUDIT_DIR, exist_ok=True)
            os.chmod(AUDIT_DIR, 0o750)
            if _CCC_GID is not None:
                os.chown(AUDIT_DIR, 0, _CCC_GID)   # root:conduit-cc
        except OSError:
            pass
        rec_fields = {"outcome": outcome, "stage": stage}
        rec_fields.update({k: v for k, v in fields.items() if v is not None})
        record = build_audit_record(rec_fields, attempt_id=_ATTEMPT_ID,
                                    correlation_id=_ATTEMPT_ID, now=_now())
        append_record(AUDIT_FILE, record)   # AppendResult discarded (non-fatal)
        try:
            os.chmod(AUDIT_FILE, 0o640)
            if _CCC_GID is not None:
                os.chown(AUDIT_FILE, 0, _CCC_GID)   # root:conduit-cc
        except OSError:
            pass
    except Exception:  # noqa: BLE001 - audit must never affect the update
        pass


def _parse_version(text: str) -> tuple[int, int, int] | None:
    m = _VERSION_RE.search(text)
    if not m:
        return None
    return tuple(int(p) for p in m.group(1).split("."))  # type: ignore[return-value]


def _parse_ver_arg(s: str) -> tuple[int, int, int]:
    if not _VER_ARG_RE.match(s or ""):
        die(2, f"invalid version argument: {s!r}")
    return tuple(int(p) for p in s.split("."))  # type: ignore[return-value]


def _version_str(v: tuple[int, int, int]) -> str:
    return ".".join(str(p) for p in v)


def write_status(state: str, **fields) -> None:
    """Publish the service-readable status document via the SAFE publisher
    (unpredictable mkstemp, parent/ownership invariants, no symlink following,
    fsync + atomic replace + parent fsync). A publication failure preserves the
    previous valid status file. See backend/priv_state.py (F2)."""
    if not _PSTATE_AVAILABLE:
        die(3, "MARKER=PRIV_STATE_IMPORT_FAILED privileged state library unavailable (fail closed)")
    doc = {"schema": 1, "state": state, "updated_at": _now()}
    doc.update(fields)
    _pstate.publish_status(STATUS_PATH, doc, owner_uid=_OWNER_UID, group_gid=_CCC_GID)


MAX_UNCOMPRESSED_BYTES = 400 * 1024 * 1024                 # source + wheelhouse ceiling


def _safe_extract(tar: tarfile.TarFile, dest: str, allowed_top_level) -> None:
    """Fail-closed extraction of the (already signature+digest-verified) artifact.
    Defense-in-depth: reject traversal/abs paths, symlinks/hardlinks, device/FIFO/
    special members, duplicate member names; enforce the SIGNED top-level allowlist
    (every member's top-level component must be in `allowed_top_level`, the set bound
    in the verified manifest for THIS platform -- so a non-armv7l payload cannot carry
    a wheelhouse and no unexpected root is ever accepted); cap total uncompressed size;
    and gate on free disk space (fail closed on insufficient space OR an inability to
    query it -- the pre-extraction gate, not merely the extractall handler)."""
    dest_abs = os.path.realpath(dest)
    allowed = set(allowed_top_level or ())
    seen: set = set()
    total = 0
    for member in tar.getmembers():
        target = os.path.realpath(os.path.join(dest, member.name))
        if not (target == dest_abs or target.startswith(dest_abs + os.sep)):
            die(3, f"unsafe path in tarball: {member.name!r}")
        if member.issym() or member.islnk():
            die(3, f"links not allowed in tarball: {member.name!r}")
        if not (member.isfile() or member.isdir()):
            die(3, f"special file not allowed in tarball: {member.name!r}")
        if member.name in seen:
            die(3, f"duplicate member in tarball: {member.name!r}")
        seen.add(member.name)
        top = member.name.split("/", 1)[0]
        if top not in allowed:
            die(3, f"unexpected top-level member {member.name!r} (not in signed allowlist)")
        total += max(0, member.size)
        if total > MAX_UNCOMPRESSED_BYTES:
            die(3, "tarball uncompressed size exceeds limit")
    # Pre-extraction free-space GATE (fail closed): both insufficient space AND an
    # inability to query it abort before any file is written.
    try:
        free = shutil.disk_usage(dest).free
    except OSError as exc:
        die(3, f"cannot determine free space to extract safely: {exc}")
    if free < total + (32 * 1024 * 1024):
        die(3, "insufficient disk space to extract update")
    # Defense-in-depth: any OSError during extraction also fails closed.
    try:
        try:
            tar.extractall(dest, filter="data")  # Python >= 3.12
        except TypeError:
            tar.extractall(dest)  # older Python; guarded by the checks above
    except OSError as exc:
        die(3, f"extraction failed (disk/io): {exc}")


def _read_installed_version() -> tuple[int, int, int]:
    try:
        with open(INSTALLED_VERSION_PY, encoding="utf-8") as fh:
            v = _parse_version(fh.read())
    except OSError as exc:
        die(3, f"cannot read installed version: {exc}")
    if v is None:
        die(3, "installed APP_VERSION not found")
    return v


def _derive_tree(work_abs: str) -> str:
    """Locate the CCC source tree under work/src/ (GitHub tarballs wrap everything
    in a single top-level directory)."""
    src = os.path.join(work_abs, "src")
    entries = [os.path.join(src, e) for e in os.listdir(src)] if os.path.isdir(src) else []
    dirs = [e for e in entries if os.path.isdir(e)]
    return dirs[0] if len(dirs) == 1 else src


def _read_exact(n: int) -> bytes:
    """Read exactly n bytes from stdin, or die on truncation."""
    buf = bytearray()
    while len(buf) < n:
        chunk = sys.stdin.buffer.read(n - len(buf))
        if not chunk:
            _audit(OUTCOME_REJECT_FRAME, "operational")
            die(2, "truncated payload frame")
        buf += chunk
    return bytes(buf)


def _read_framed_payload(work: str) -> tuple[str, str, str]:
    """Read the ADR-0003 framed payload {manifest, signature, artifact} from stdin
    and write each to a file under work/. Returns their paths. Fail-closed on any
    malformed frame (magic + three length-prefixed records)."""
    if _read_exact(len(_FRAME_MAGIC)) != _FRAME_MAGIC:
        _audit(OUTCOME_REJECT_FRAME, "operational")
        die(2, "bad payload frame header")
    names = ("manifest.json", "manifest.json.sig", "payload.tar.gz")
    paths = []
    total = 0
    for name in names:
        (n,) = struct.unpack(">Q", _read_exact(8))
        total += n
        if n > MAX_PAYLOAD_BYTES or total > MAX_PAYLOAD_BYTES:
            _audit(OUTCOME_REJECT_FRAME, "operational")
            die(2, "payload exceeds size limit")
        data = _read_exact(n) if n else b""
        path = os.path.join(work, name)
        with open(path, "wb") as fh:
            fh.write(data)
        paths.append(path)
    return paths[0], paths[1], paths[2]


def _ingest_payload(work: str) -> tuple[str, tuple[int, int, int]]:
    """Read the framed signed payload from stdin, VERIFY it against the on-device
    trust store (fail-closed, BEFORE extraction and the version gate), then extract
    and locate the source tree. Returns (tree_path, payload_version)."""
    global _LAST_META
    if not _VERIFY_AVAILABLE:
        _audit("reject_tooling", "verify")   # verifier module absent -> constants unavailable; documented literal fallback
        die(2, "update rejected: verifier unavailable")
    manifest_p, sig_p, artifact_p = _read_framed_payload(work)

    # Independent platform authority: the REAL host arch, detected here in the host
    # namespace as root -- never taken from the payload or the untrusted backend.
    host_platform = os.uname().machine

    # --- the single, fail-closed verification decision (ADR-0003) --------------
    # Digest-to-platform-entry binding is the ROOT authorization: the received
    # bytes are bound to the SIGNED entry for this host platform only; an artifact
    # matching a different platform's entry (or an unknown platform) is rejected
    # with no fallback. (The frame carries no independent filename, so there is no
    # received-name check; the manifest's per-entry name is a signed self-consistency
    # field validated inside verify_release.)
    result = verify_release(manifest_path=manifest_p, signature_path=sig_p,
                            artifact_path=artifact_p, trust_store_path=TRUST_STORE,
                            platform=host_platform)
    if not result.ok:
        _audit(result.reason, "verify")
        die(2, f"update rejected: {result.reason}")
    if not product_scope_ok(result.metadata):
        _audit(OUTCOME_REJECT_PRODUCT_SCOPE, "authorize",
               verified_version=result.metadata.get("version"),
               signing_principal=result.metadata.get("signing_principal"))
        die(2, "update rejected: wrong product")
    _LAST_META = result.metadata   # verified metadata (audit only; apply-side points)

    extract_dir = os.path.join(work, "src")
    os.makedirs(extract_dir, exist_ok=True)
    try:
        with tarfile.open(artifact_p, "r:gz") as tar:
            _safe_extract(tar, extract_dir, result.metadata.get("top_level"))
    except tarfile.TarError as exc:
        _audit(OUTCOME_REJECT_PAYLOAD_SHAPE, "deploy",
               verified_version=result.metadata.get("version"),
               signing_principal=result.metadata.get("signing_principal"))
        die(2, f"cannot read payload tarball: {exc}")

    tree = _derive_tree(work)
    if not os.path.isfile(os.path.join(tree, PAYLOAD_UPDATE_REL)) or \
       not os.path.isfile(os.path.join(tree, PAYLOAD_VERSION_REL)):
        _audit(OUTCOME_REJECT_PAYLOAD_SHAPE, "deploy",
               verified_version=result.metadata.get("version"),
               signing_principal=result.metadata.get("signing_principal"))
        die(2, "payload is not a CCC source tree (missing update.sh/_version.py)")

    with open(os.path.join(tree, PAYLOAD_VERSION_REL), encoding="utf-8") as fh:
        pv = _parse_version(fh.read())
    if pv is None:
        _audit(OUTCOME_REJECT_PAYLOAD_SHAPE, "deploy",
               verified_version=result.metadata.get("version"),
               signing_principal=result.metadata.get("signing_principal"))
        die(2, "payload APP_VERSION not found")

    # cross-check the verified manifest version against the payload's own version
    if not cross_check_version(result.metadata, _version_str(pv)):
        _audit(OUTCOME_REJECT_VERSION_MISMATCH, "cross-check",
               verified_version=result.metadata.get("version"),
               signing_principal=result.metadata.get("signing_principal"))
        die(2, "update rejected: manifest/payload version mismatch")
    return tree, pv


def _sweep_stale_workdirs() -> None:
    """Clean leftover work trees from prior interrupted runs. Deletion authority
    is the per-attempt OWNERSHIP RECORD (backend/priv_state.py), never a name
    prefix: only recorded, validated, contained paths are removed; anything
    unrecorded or substituted inside the private dir is PRESERVED (diagnosable
    foreign object) and reported. Called only while holding the apply flock with
    no active update unit. Never raises."""
    try:
        failed = _pstate.sweep_stale_attempts(PRIVATE_DIR, ATTEMPTS_DIR, _OWNER_UID)
        for attempt_id in failed:
            log(f"sweep: preserved undeletable/foreign attempt state: {attempt_id}")
    except _pstate.PrivStateError as exc:
        log(f"sweep skipped (state invariant): {exc}")
    except OSError:
        pass


def _cleanup_attempt_quiet(attempt_id: str, argv_work: "str | None" = None) -> None:
    """THE only deletion path in this helper (A2): record-authorized cleanup of
    THIS attempt's work tree via backend.priv_state.cleanup_attempt (identity
    tuple: id, record, argv/record path equality, containment, real-directory
    type, current dev/ino). Anything invalid is PRESERVED and logged. Never
    raises."""
    try:
        _pstate.cleanup_attempt(PRIVATE_DIR, ATTEMPTS_DIR, attempt_id, _OWNER_UID,
                                argv_work=argv_work)
    except (_pstate.PrivStateError, OSError) as exc:
        log(f"cleanup preserved attempt state {attempt_id}: {exc}")


def _unit_state(unit: str) -> "str | None":
    """Return systemd's exact state, or None when it cannot be determined."""
    try:
        r = subprocess.run(
            [SYSTEMCTL, "is-active", unit],
            stdin=subprocess.DEVNULL,
            capture_output=True,
            text=True,
            check=False,
        )
    except OSError:
        return None
    state = (r.stdout or "").strip()
    return state or None


def _unit_busy() -> bool:
    """True when either fixed privileged lifecycle unit is in flight."""
    return any(
        _unit_state(unit) in _IN_FLIGHT_UNIT_STATES
        for unit in (UPDATE_UNIT, RESTORE_UNIT)
    )


# --------------------------------------------------------------------------- #
#  Worker  (runs INSIDE the transient unit, in the HOST mount namespace)       #
# --------------------------------------------------------------------------- #
def _run_update(tree: str, frm: tuple[int, int, int], to: tuple[int, int, int],
                update_id: str, work: str, source_commit: str,
                source_tag: str) -> int:
    """in_progress -> run installed update.sh -> terminal status -> cleanup.
    update.sh stdout/stderr are captured to WORKER_LOG. Returns a process exit code."""
    write_status("in_progress", id=update_id, pid=os.getpid(),
                 from_version=_version_str(frm), to_version=_version_str(to),
                 started_at=_now(), message="Applying CCC update")

    # Capture update.sh output to a per-run worker log (root 0600, O_NOFOLLOW).
    try:
        logfd = _pstate.open_private_log(WORKER_LOG, _OWNER_UID)
        logf = os.fdopen(logfd, "w")
    except (OSError, _pstate.PrivStateError):
        logf = None
    try:
        if logf is not None:
            logf.write(f"=== ccc-update-apply worker {update_id}: "
                       f"{_version_str(frm)} -> {_version_str(to)} @ {_now()} ===\n")
            logf.flush()
        # Pin the wheelhouse to the VERIFIED tree for armv7l; strip any inherited
        # CCC_WHEELHOUSE_DIR so an injected env var can NEVER redirect privileged
        # pip to unverified local content. aarch64 gets no wheelhouse (index path).
        _env = dict(os.environ)
        _env.pop("CCC_WHEELHOUSE_DIR", None)
        if os.uname().machine == "armv7l":
            _env["CCC_WHEELHOUSE_DIR"] = os.path.join(tree, "wheelhouse-armhf")
        try:
            proc = subprocess.run(
                ["bash", INSTALLED_UPDATE_SH,
                 "--ccc-only", "--non-interactive", "--source", tree,
                 "--update-attempt-id", update_id,
                 "--authorized-source-commit", source_commit,
                 "--authorized-source-tag", source_tag],
                check=False,
                env=_env,
                stdin=subprocess.DEVNULL,
                stdout=(logf if logf is not None else None),
                stderr=(subprocess.STDOUT if logf is not None else None),
            )
            rc = proc.returncode
        except OSError as exc:
            write_status("failed", id=update_id, from_version=_version_str(frm),
                         to_version=_version_str(to), finished_at=_now(),
                         message=f"could not launch updater: {exc}")
            _audit(OUTCOME_LAUNCH_FAILED, "deploy",
                   from_version=_version_str(frm), target_version=_version_str(to))
            _cleanup_attempt_quiet(update_id, argv_work=work)
            return 3
    finally:
        if logf is not None:
            logf.close()

    new_installed = _read_installed_version()
    if rc == 0 and new_installed == to:
        write_status("success", id=update_id, from_version=_version_str(frm),
                     to_version=_version_str(to), finished_at=_now(),
                     message="Update complete")
        _audit(OUTCOME_APPLIED, "deploy",
               from_version=_version_str(frm), target_version=_version_str(to))
    elif new_installed == frm:
        write_status("rolled_back", id=update_id, from_version=_version_str(frm),
                     to_version=_version_str(to), finished_at=_now(),
                     message=f"Update failed (rc={rc}); rolled back to {_version_str(frm)}")
        _audit(OUTCOME_REVERTED, "deploy",
               from_version=_version_str(frm), target_version=_version_str(to))
    else:
        write_status("failed", id=update_id, from_version=_version_str(frm),
                     to_version=_version_str(to), finished_at=_now(),
                     message=f"Update ended in an unexpected state (rc={rc}); see /var/backups/conduit-cc")
        _audit(OUTCOME_APPLY_FAILED, "deploy",
               from_version=_version_str(frm), target_version=_version_str(to))
    # Terminal status written above -> record-authorized removal of the current
    # extraction dir and its ownership record (A2: single deletion authority).
    _cleanup_attempt_quiet(update_id, argv_work=work)
    return 0


def run_worker_cmd(argv) -> None:
    """Internal entrypoint executed by the transient unit. NOT a public action."""
    if not _PSTATE_AVAILABLE:
        die(3, "privileged attempt-state library unavailable")
    p = argparse.ArgumentParser(prog="ccc-update-apply __run-worker", add_help=False)
    p.add_argument("--work", required=True)
    p.add_argument("--from", dest="frm", required=True)
    p.add_argument("--to", dest="to", required=True)
    p.add_argument("--id", dest="uid", required=True)
    p.add_argument("--source-commit", required=True)
    p.add_argument("--source-tag", required=True)
    try:
        a = p.parse_args(argv)
    except SystemExit:
        die(2, "invalid __run-worker arguments")

    frm = _parse_ver_arg(a.frm)
    to = _parse_ver_arg(a.to)
    uid = a.uid
    source_commit = a.source_commit
    source_tag = a.source_tag

    def _fail(code: int, msg: str, outcome: "str | None" = None) -> NoReturn:
        if outcome is None and _VERIFY_AVAILABLE:
            outcome = OUTCOME_REJECT_PAYLOAD_SHAPE
        if outcome:
            _audit(outcome, "deploy", from_version=_version_str(frm), target_version=_version_str(to))
        write_status("failed", id=uid, from_version=_version_str(frm),
                     to_version=_version_str(to), finished_at=_now(), message=msg)
        # A2: NEVER delete the raw --work argument. Record-authorized cleanup
        # only; invalid/outside/unrecorded/mismatched objects survive for
        # diagnosis (the sweep handles recorded orphans later).
        _cleanup_attempt_quiet(uid, argv_work=a.work)
        sys.exit(code)

    # The transient-unit argv identifies the attempt but never authorizes its
    # filesystem path.  Execution authority comes from the exact, kind-bound
    # ownership record created before ingest.  On an authorization failure no
    # cleanup is permitted: the object may belong to another operation kind.
    try:
        work_abs = _pstate.attempt_work(
            PRIVATE_DIR,
            ATTEMPTS_DIR,
            uid,
            kind="update",
            owner_uid=_OWNER_UID,
            argv_work=a.work,
        )
    except (_pstate.PrivStateError, OSError):
        # The attempt id/path are not trusted until the record authorizes them.
        # Do not publish status, audit as this attempt, or delete anything.
        die(3, "work directory is not authorized by this update attempt")

    global _ATTEMPT_ID
    _ATTEMPT_ID = uid   # authorized worker records correlate with this attempt

    tree = _derive_tree(work_abs)
    if not (os.path.isfile(os.path.join(tree, PAYLOAD_UPDATE_REL)) and
            os.path.isfile(os.path.join(tree, PAYLOAD_VERSION_REL))):
        _fail(3, "work tree is not a CCC source tree")
    try:
        with open(os.path.join(tree, PAYLOAD_VERSION_REL), encoding="utf-8") as fh:
            pv = _parse_version(fh.read())
    except OSError as exc:
        _fail(3, f"cannot read payload version: {exc}")
    if pv != to:
        _fail(3, f"work tree version {pv} does not match expected {_version_str(to)}")
    if not re.fullmatch(r"[0-9a-f]{40}", source_commit):
        _fail(3, "verified source commit is malformed")
    if source_tag != f"v{_version_str(to)}":
        _fail(3, "verified source tag does not match the target version")

    installed = _read_installed_version()
    if not (to > installed and installed == frm):
        _fail(2, f"refusing non-upgrade: installed {_version_str(installed)}, "
                 f"from {_version_str(frm)}, to {_version_str(to)}",
              outcome=(OUTCOME_REJECT_NON_UPGRADE if _VERIFY_AVAILABLE else None))

    sys.exit(_run_update(tree, installed, to, uid, work_abs,
                         source_commit, source_tag))


# --------------------------------------------------------------------------- #
#  apply  (runs INSIDE conduit-cc.service ns: ingest only, then launch unit)   #
# --------------------------------------------------------------------------- #
def _launch_update_unit(work: str, frm: tuple[int, int, int],
                        to: tuple[int, int, int], update_id: str,
                        source_commit: str, source_tag: str) -> int:
    """Start the fixed-name transient unit running THIS helper's worker subcommand
    in the host namespace. Returns 0 on success."""
    cmd = [
        SYSTEMD_RUN, "--collect", "--no-block", "--quiet",
        f"--unit={UPDATE_UNIT}",
        "--description=Conduit Control Center one-click update",
        SELF_PATH, "__run-worker",
        "--work", work,
        "--from", _version_str(frm),
        "--to", _version_str(to),
        "--id", update_id,
        "--source-commit", source_commit,
        "--source-tag", source_tag,
    ]

    def _try():
        try:
            return subprocess.run(cmd, stdin=subprocess.DEVNULL,
                                  stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                                  text=True, check=False)
        except OSError as exc:
            log(f"systemd-run not runnable: {exc}")
            return None

    proc = _try()
    if proc is None:
        return 3
    if proc.returncode != 0:
        log(f"systemd-run failed (rc={proc.returncode}): {(proc.stdout or '').strip()}")
        # Clear a possibly-lingering inactive/failed unit object, then retry once.
        try:
            subprocess.run([SYSTEMCTL, "reset-failed", UPDATE_UNIT],
                           stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL,
                           stderr=subprocess.DEVNULL, check=False)
        except OSError:
            pass
        proc = _try()
        if proc is None or proc.returncode != 0:
            if proc is not None:
                log(f"systemd-run retry failed (rc={proc.returncode}): {(proc.stdout or '').strip()}")
            return (proc.returncode if proc else 1) or 1
    return 0


def _ensure_state_dirs() -> None:
    if _PSTATE_AVAILABLE:
        # positive import-success marker (installed-layout proof observes this;
        # never inferred from an ambiguous exit code)
        sys.stderr.write("ccc-update-apply: MARKER=PRIV_STATE_IMPORT_OK\n")
    """Create/normalize the Epic-1 state boundary, then ASSERT its invariants
    (fail-closed). Modes are re-applied every run so drift cannot persist."""
    if not _PSTATE_AVAILABLE:
        die(3, "MARKER=PRIV_STATE_IMPORT_FAILED privileged state library unavailable (fail closed)")
    try:
        for d, m in ((PRIVATE_DIR, 0o700), (ATTEMPTS_DIR, 0o700), (PUBLIC_STATUS_DIR, 0o755)):
            os.makedirs(d, exist_ok=True)
            os.chmod(d, m)
            if os.geteuid() == 0:
                os.chown(d, 0, 0)
    except OSError as exc:
        die(3, f"MARKER=STATE_DIRS_INVALID cannot provision state dirs: {exc}")
    try:
        _pstate.assert_private_dir(PRIVATE_DIR, _OWNER_UID)
        _pstate.assert_private_dir(ATTEMPTS_DIR, _OWNER_UID)
        _pstate.assert_public_dir(PUBLIC_STATUS_DIR, _OWNER_UID)
    except _pstate.PrivStateError as exc:
        die(3, f"MARKER=STATE_DIRS_INVALID state boundary invariant failed: {exc}")


def apply_cmd() -> None:
    global _ATTEMPT_ID
    _ensure_state_dirs()
    # Correlation id generated EARLY so pre-ack rejects are auditable. It is the
    # SAME value later surfaced by the ack and the status `id` (format/semantics
    # unchanged); pre-ack rejects still emit no status/ack, only an audit record.
    _ATTEMPT_ID = update_id = uuid.uuid4().hex[:12]
    try:
        lock_fd = _pstate.open_private_lock(LOCK_PATH, _OWNER_UID)
    except _pstate.PrivStateError as exc:
        die(3, f"cannot open private update lock: {exc}")
    try:
        fcntl.flock(lock_fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:
        die(2, "another update is already in progress")

    # Run-phase mutex: if the transient unit is already active, refuse and do NOT
    # sweep (the active run owns a work dir). Held flock serializes apply calls.
    if _unit_busy():
        die(2, "another update or restore is already in progress")

    # Flock held + no active unit -> any leftover ccc-update-* dir is an orphan.
    _sweep_stale_workdirs()

    installed = _read_installed_version()
    # OWNERSHIP RECORD FIRST, then the directory: an interruption at any point
    # leaves either nothing or a recorded path, never an unowned orphan. The
    # deterministic name is safe inside the root-only 0700 private dir.
    work = os.path.join(PRIVATE_DIR, f"ccc-update-{update_id}")
    try:
        _pstate.record_attempt(
            ATTEMPTS_DIR, update_id, work, _OWNER_UID, kind="update")
    except _pstate.PrivStateError as exc:
        die(3, f"cannot record attempt ownership: {exc}")
    os.mkdir(work, 0o700)
    tree, payload_v = _ingest_payload(work)

    if payload_v <= installed:
        _audit(OUTCOME_REJECT_NON_UPGRADE, "authorize",
               from_version=_version_str(installed), target_version=_version_str(payload_v),
               signing_principal=(_LAST_META or {}).get("signing_principal"))
        _cleanup_attempt_quiet(update_id)
        die(2, f"refusing non-upgrade: payload {_version_str(payload_v)} "
               f"<= installed {_version_str(installed)} (no downgrade/reinstall)")

    # Source identity is part of worker authorization, so validate it BEFORE
    # emitting the accepted ack. A source-binding failure must remain a
    # synchronous rejection, never a false "scheduled" API response.
    source = (_LAST_META or {}).get("source") or {}
    source_commit = source.get("commit")
    source_tag = source.get("tag")
    if not isinstance(source_commit, str) or not re.fullmatch(r"[0-9a-f]{40}", source_commit):
        _cleanup_attempt_quiet(update_id)
        die(2, "verified manifest source commit is unavailable")
    if source_tag != f"v{_version_str(payload_v)}":
        _cleanup_attempt_quiet(update_id)
        die(2, "verified manifest source tag/version binding is unavailable")

    sys.stdout.write(f"accepted {update_id}\n")
    sys.stdout.flush()
    _audit(OUTCOME_ACCEPTED, "authorize",
           from_version=_version_str(installed), target_version=_version_str(payload_v),
           verified_version=(_LAST_META or {}).get("version"),
           signing_principal=(_LAST_META or {}).get("signing_principal"))

    # Launch the trusted worker in a fixed-name systemd transient unit, which runs
    # in the HOST mount namespace (outside conduit-cc.service's ProtectSystem=strict),
    # so update.sh can write /opt, /var/backups, etc.
    rc = _launch_update_unit(work, installed, payload_v, update_id,
                             source_commit, source_tag)
    if rc != 0:
        # systemd-run can report failure even when the fixed unit was registered
        # and is already starting.  Only publish a terminal launch failure and
        # delete the attempt after proving the unit is definitely not running.
        # Active, transitional, unknown, empty, or unqueryable states preserve
        # both the worker-owned attempt and its future status authority.
        unit_state = _unit_state(UPDATE_UNIT)
        if unit_state not in _DEFINITELY_INACTIVE_UNIT_STATES:
            log(
                "systemd-run returned nonzero but update-unit state is "
                f"{unit_state or 'unavailable'}; preserving attempt ownership"
            )
            os._exit(0)  # ack already sent; worker or Owner diagnosis owns state
        _audit(OUTCOME_LAUNCH_FAILED, "deploy",
               from_version=_version_str(installed), target_version=_version_str(payload_v),
               signing_principal=(_LAST_META or {}).get("signing_principal"))
        write_status("failed", id=update_id, from_version=_version_str(installed),
                     to_version=_version_str(payload_v), finished_at=_now(),
                     message="Could not launch the update unit; no changes were made.")
        _cleanup_attempt_quiet(update_id)
        os._exit(0)   # ack already sent; status reflects the failure

    # Hold the flock until the unit registers as active, closing the launch gap so
    # a concurrent apply is rejected (by flock, then by _unit_busy) before sweeping.
    deadline = time.monotonic() + _ACTIVE_WAIT_S
    while time.monotonic() < deadline:
        if _unit_busy():
            break
        time.sleep(0.2)
    os._exit(0)   # releasing the flock; the transient unit carries the run


def main() -> None:
    args = sys.argv[1:]
    if args == ["apply"]:
        apply_cmd()
    elif args and args[0] == "__run-worker":
        run_worker_cmd(args[1:])
    else:
        die(2, "usage: ccc-update-apply apply   (payload tarball on stdin)")


if __name__ == "__main__":
    main()
