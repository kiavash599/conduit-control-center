# =============================================================================
# Conduit Control Center -- Environment Variables
# =============================================================================
#
# HOW TO USE:
#   cp .env.example .env
#   Edit .env and fill in your values.
#   NEVER commit .env to git. It is in .gitignore.
#
# PRODUCTION:
#   On a live server, this file is installed at /etc/conduit-cc/.env
#   by install.sh with permissions 640, owned by the conduit-cc service user.
# =============================================================================


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# 32-byte cryptographically random secret used to sign session IDs.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED. The application will refuse to start if this is not set.
SESSION_SECRET=replace_with_a_32_byte_random_hex_string

# Port FastAPI listens on. Nginx proxies to this port.
# Do NOT expose this port directly to the internet.
# Default: 8000
APP_PORT=8000

# Log level for the application. Options: DEBUG, INFO, WARNING, ERROR
# Use DEBUG during development, INFO in production.
# Default: INFO
LOG_LEVEL=INFO

# Set to false in local HTTP development to allow session cookies over HTTP.
# MUST be true (or omitted) in any internet-facing deployment.
# Default: true
SECURE_COOKIES=true


# -----------------------------------------------------------------------------
# Cloudflare DDNS
# Required for the cloudflare-ddns.sh script.
# See docs/pre-install.md for how to create the API token.
# -----------------------------------------------------------------------------

# Cloudflare API token.
# Required permissions: Zone:DNS:Edit and Zone:Zone:Read
# Scope: Specific zone only -- NOT a Global API key.
# Create at: https://dash.cloudflare.com/profile/api-tokens
# SECURITY: This token is high-value. Keep it secret. Never log it.
CF_API_TOKEN=your_cloudflare_api_token_here

# The root domain managed by Cloudflare.
# Example: rockysystem.net
CF_ZONE_NAME=yourdomain.com

# The full hostname of the dashboard DNS A record.
# Example: conduit.rockysystem.net
CF_RECORD_NAME=conduit.yourdomain.com


# -----------------------------------------------------------------------------
# TLS -- Cloudflare Origin Certificate (Primary deployment path)
# See docs/tls-setup.md for setup instructions.
# -----------------------------------------------------------------------------

# Absolute path to the Cloudflare Origin Certificate file (.pem).
# Created at: Cloudflare Dashboard -> SSL/TLS -> Origin Server -> Create Certificate
# Installed at: /etc/conduit-cc/tls/origin.pem by install.sh
TLS_CERT_PATH=/etc/conduit-cc/tls/origin.pem

# Absolute path to the Origin Certificate private key file (.key).
# Installed at: /etc/conduit-cc/tls/origin.key by install.sh
# Permissions must be 640, owned by conduit-cc service user.
TLS_KEY_PATH=/etc/conduit-cc/tls/origin.key


# -----------------------------------------------------------------------------
# Admin Account
# Set during installation by install.sh. Do not edit manually after install.
# To change the password, use the Settings page in the dashboard.
# -----------------------------------------------------------------------------

# Username for the single admin account.
# Default: admin
# Change only if "admin" conflicts with an existing system user or policy.
# If you change this, the value is stored in sessions and audit logs --
# it does not affect password hashing (hashes are password-only in bcrypt).
# Used by: login endpoint, lockout checks, ccc-unlock script.
ADMIN_USERNAME=admin

# bcrypt hash of the admin password. Generated by install.sh.
# Never store the plaintext password here.
# Generate manually:
#   python3 -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=
