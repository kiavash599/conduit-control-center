# Auto detect text files and perform LF normalization
* text=auto

*.sh text eol=lf
deployment/bin/* text eol=lf

# Deployment artifacts (systemd units, nginx, logrotate, etc.) are consumed
# byte-for-byte by Linux-side guards (e.g. update.sh BS1 reduced-mode check,
# which anchors on `^Environment=CCC_MAX_PERSONAL_CLIENTS=0$`). A CRLF checkout
# would break those exact-line matches, so pin them to LF everywhere.
deployment/* text eol=lf

# Dual-origin armv7 release-security artifacts. Their sha256 is bound into
# provenance / authorizations and recomputed at every trust boundary. The
# hashing is LF-canonical in code (reuse_authz.canonical_lf) so a CRLF checkout
# still produces the correct digest, but we ALSO pin them LF on disk so the
# working tree matches the committed bytes exactly (no accidental CRLF drift).
requirements-armv7-solution.lock text eol=lf
requirements-armv7-build.lock text eol=lf
release/builder/target-supported-tags.txt text eol=lf
release/builder/armv7-reuse-authz.json text eol=lf
