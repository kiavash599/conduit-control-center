# =============================================================================
# Canonical armv7l (armhf) wheelhouse builder — Conduit Control Center (ADR-0003 A1)
# =============================================================================
# Committed + provenance-bound. Its sha256 is recorded in provenance.builder.recipe_sha256.
# TARGET COMPATIBILITY (finding 8): the base MUST be Ubuntu 22.04 (Jammy) armhf so the
# built glibc baseline is <= the production RPi2 target (glibc 2.35). Do NOT use Debian
# Bookworm (newer glibc) — wheels could import in the builder yet fail on Jammy.
#
# The base image MUST be supplied digest-pinned via CCC_BASE_IMAGE (no default -> fails
# closed), e.g. --build-arg CCC_BASE_IMAGE=docker.io/arm32v7/ubuntu:22.04@sha256:<digest>.
#
# Connected inputs are PINNED/VERIFIED, or the build fails closed (finding 7):
#   * apt packages come from apt-packages.list with exact name=version (unpinned -> fail);
#   * rustup-init is downloaded for a pinned version and sha256-verified against the
#     committed rustup-init.sha256;
#   * PEP 517 backends install --require-hashes from requirements-build-backends.lock,
#     which must be NON-EMPTY (comment-only/empty -> fail closed, finding 1).
# The three input files (apt-packages.list, rustup-init.sha256,
# requirements-build-backends.lock) are committed for the release (see *.example
# templates in release/lock-schema/); they are absent until the controlled build, so the
# image build fails closed until they are populated + committed.
# =============================================================================
ARG CCC_BASE_IMAGE
FROM ${CCC_BASE_IMAGE}

ARG RUST_VERSION=1.75.0
ARG RUSTUP_VERSION=1.27.1
LABEL org.opencontainers.image.title="ccc-armv7-wheelhouse-builder" \
      org.conduit-cc.builder.recipe="release/builder/Containerfile"
SHELL ["/bin/bash", "-euo", "pipefail", "-c"]

# --- OS build toolchain (Jammy), pinned by name=version; unpinned fails closed ---
COPY apt-packages.list /opt/ccc/apt-packages.list
RUN export DEBIAN_FRONTEND=noninteractive; \
    awk 'NF && $1 !~ /^#/ { if ($0 !~ /=/) { print "UNPINNED apt package: " $0 > "/dev/stderr"; exit 1 } }' \
        /opt/ccc/apt-packages.list; \
    apt-get update; \
    grep -vE '^[[:space:]]*#|^[[:space:]]*$' /opt/ccc/apt-packages.list \
        | xargs apt-get install -y --no-install-recommends; \
    rm -rf /var/lib/apt/lists/*

# --- Rust: pinned installer, sha256-verified against the committed digest ---
ENV RUSTUP_HOME=/opt/rust/rustup CARGO_HOME=/opt/rust/cargo PATH=/opt/rust/cargo/bin:$PATH
COPY rustup-init.sha256 /opt/ccc/rustup-init.sha256
RUN arch=armv7-unknown-linux-gnueabihf; \
    curl --proto '=https' --tlsv1.2 -fsSL \
        "https://static.rust-lang.org/rustup/archive/${RUSTUP_VERSION}/${arch}/rustup-init" -o /tmp/rustup-init; \
    printf '%s  /tmp/rustup-init\n' "$(cat /opt/ccc/rustup-init.sha256)" | sha256sum -c -; \
    chmod +x /tmp/rustup-init; \
    /tmp/rustup-init -y --no-modify-path --profile minimal --default-toolchain "${RUST_VERSION}"; \
    rm -f /tmp/rustup-init; rustc --version; cargo --version

# --- PEP 517 build backends: reject empty/comment-only, then hash-pinned install ---
ENV CARGO_BUILD_JOBS=1 MAKEFLAGS=-j1 CARGO_PROFILE_RELEASE_CODEGEN_UNITS=1
COPY requirements-build-backends.lock /opt/ccc/requirements-build-backends.lock
RUN python3 -c "import sys; L=[l for l in open('/opt/ccc/requirements-build-backends.lock') if l.strip() and not l.lstrip().startswith('#')]; sys.exit(0 if L else 1)" \
      || { echo 'ERROR: empty/comment-only build-backends lock (fail closed)' >&2; exit 1; }; \
    python3 -m pip install --no-cache-dir --require-hashes --only-binary=:all: \
        -r /opt/ccc/requirements-build-backends.lock

RUN useradd --create-home --uid 1000 --shell /usr/sbin/nologin builder \
    && mkdir -p /work && chown -R builder:builder /work
USER builder
WORKDIR /work
